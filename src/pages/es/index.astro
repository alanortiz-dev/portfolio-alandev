---
import AboutMe from '@/components/AboutMe.astro';
import Experience from '@/components/Experience.astro';
import FeaturedProjects from '@/components/FeaturedProjects.astro';
import Hero from '@/components/Hero.astro';
import ProductionDeployments from '@/components/ProductionDeployments.astro';
import SectionContainer from '@/components/SectionContainer.astro';
import TitleSection from '@/components/TitleSection.astro';
import { homeContent } from '@/data/homeContent';
import Layout from '@/layouts/Layout.astro';

const content = homeContent.es;
---

<Layout title={content.meta.title} description={content.meta.description}>
  <main id="top" class="pb-8 pt-8 md:pt-12">
    <SectionContainer>
      <Hero content={content} />
    </SectionContainer>

    <div>
      <SectionContainer id="featured-engineering" class="pt-6 lg:pt-7">
        <FeaturedProjects content={content} />
      </SectionContainer>

      <SectionContainer id="production-deployments" class="pt-6 lg:pt-7">
        <ProductionDeployments content={content} />
      </SectionContainer>

      <SectionContainer id="experience-timeline" class="pt-6 pb-20 lg:pt-7 md:pb-28">
        <Experience content={content} />
      </SectionContainer>

      <SectionContainer id="about" class="pt-8 pb-20 md:pt-10 md:pb-28" narrow={true}>
        <TitleSection>{content.sectionTitles.about}</TitleSection>
        <AboutMe content={content} />
      </SectionContainer>
    </div>
  </main>
</Layout>
