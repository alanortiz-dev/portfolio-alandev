---
import AboutMe from '@/components/AboutMe.astro';
import EngineeringPrinciples from '@/components/EngineeringPrinciples.astro';
import Experience from '@/components/Experience.astro';
import FeaturedProjects from '@/components/FeaturedProjects.astro';
import Hero from '@/components/Hero.astro';
import ProductionDeployments from '@/components/ProductionDeployments.astro';
import ProductionExperience from '@/components/ProductionExperience.astro';
import ProofStrip from '@/components/ProofStrip.astro';
import SectionContainer from '@/components/SectionContainer.astro';
import TitleSection from '@/components/TitleSection.astro';
import { homeContent } from '@/data/homeContent';
import Layout from '@/layouts/Layout.astro';

const content = homeContent.en;
---

<Layout title={content.meta.title} description={content.meta.description}>
  <main class="px-4 pb-6 pt-10 md:pt-16">
    <SectionContainer class="py-10 md:py-20">
      <div class="space-y-8">
        <Hero content={content} />
        <ProofStrip content={content} />
      </div>
    </SectionContainer>

    <div class="space-y-24 md:space-y-28">
      <SectionContainer id="featured-engineering">
        <TitleSection>{content.sectionTitles.featured}</TitleSection>
        <p class="mb-8 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{content.sectionTitles.featuredIntro}</p>
        <FeaturedProjects content={content} />
      </SectionContainer>

      <SectionContainer id="production-experience">
        <TitleSection>{content.sectionTitles.production}</TitleSection>
        <p class="mb-8 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{content.sectionTitles.productionIntro}</p>
        <ProductionExperience content={content} />
      </SectionContainer>

      <SectionContainer id="production-deployments">
        <TitleSection>{content.sectionTitles.deployments}</TitleSection>
        <p class="mb-8 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{content.sectionTitles.deploymentsIntro}</p>
        <ProductionDeployments content={content} />
      </SectionContainer>

      <SectionContainer id="engineering-principles">
        <TitleSection>{content.sectionTitles.principles}</TitleSection>
        <p class="mb-8 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{content.sectionTitles.principlesIntro}</p>
        <EngineeringPrinciples content={content} />
      </SectionContainer>

      <SectionContainer id="experience-timeline">
        <TitleSection>{content.sectionTitles.timeline}</TitleSection>
        <p class="mb-8 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{content.sectionTitles.timelineIntro}</p>
        <Experience content={content} />
      </SectionContainer>

      <SectionContainer id="about">
        <TitleSection>{content.sectionTitles.about}</TitleSection>
        <AboutMe content={content} />
      </SectionContainer>
    </div>
  </main>
</Layout>
