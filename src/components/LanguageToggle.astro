---
import { languageList } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

const LANGUAGES = [
  { label: 'ES', name: 'Español', value: 'es' },
  { label: 'EN', name: 'English', value: 'en' },
];

const currentLang = (Astro.currentLocale || Astro.url.pathname.split('/')[1] || 'es') as keyof typeof languageList;
const translatedLabels = useTranslations(currentLang);

const getLocalizedPath = (lang: string) => {
  const pathWithoutLocale = Astro.url.pathname.replace(/^\/(es|en)(?=\/|$)/, '');
  return `/${lang}${pathWithoutLocale || '/'}`;
};
---

<section class="space-y-1" data-language-toggle>
  <p class="px-1 text-[9px] font-semibold uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">
    {translatedLabels('settings.language')}
  </p>

  <div class="grid grid-cols-2 gap-1" role="group" aria-label={translatedLabels('language.choose')}>
    {LANGUAGES.map((lang) => (
      <a
        href={getLocalizedPath(lang.value)}
        class="language-option inline-flex min-h-7 items-center justify-center gap-1 rounded-md border border-slate-200 bg-slate-50 px-1.5 py-1 text-[11px] font-medium text-slate-700 transition hover:border-slate-300 hover:bg-white hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
        data-language-option={lang.value}
        data-active={String(currentLang === lang.value)}
        aria-current={currentLang === lang.value ? 'page' : undefined}
      >
        <span class="text-[10px] font-semibold tracking-[0.12em]">{lang.label}</span>
        <span>{lang.name}</span>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const initLanguageToggle = () => {
      document.querySelectorAll('[data-language-option]').forEach((option) => {
        if (option.dataset.languageBound === 'true') return;
        option.dataset.languageBound = 'true';

        option.addEventListener('click', () => {
          const language = option.getAttribute('data-language-option');
          if (language) localStorage.setItem('language', language);
        });
      });
    };

    if (!window.__languageToggleBound) {
      window.__languageToggleBound = true;
      document.addEventListener('astro:page-load', initLanguageToggle);
      document.addEventListener('astro:after-swap', initLanguageToggle);
    }

    initLanguageToggle();
  })();
</script>

<style>
  .language-option[data-active='true'] {
    border-color: rgba(217, 70, 239, 0.34);
    background: rgba(250, 232, 255, 0.78);
    color: rgb(126, 34, 206);
  }

  :global(.dark) .language-option[data-active='true'] {
    border-color: rgba(52, 211, 153, 0.35);
    background: rgba(16, 185, 129, 0.12);
    color: rgb(167, 243, 208);
  }
</style>
