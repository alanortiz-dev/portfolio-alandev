---
import GitHub from '@/components/icons/GitHub.astro';
import Link from '@/components/icons/Link.astro';
import React from '@/components/icons/React.astro';
import Tailwind from '@/components/icons/Tailwind.astro';
import TypeScript from '@/components/icons/TypeScript.astro';
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const ui = currentLang === 'en'
  ? {
      title: 'Featured projects',
      moreExperience: 'See more experience',
      problem: 'Problem',
      technicalDecisions: 'Technical decisions',
      proves: 'What it proves',
      stack: 'Stack',
      links: 'Links',
      viewDetails: 'View technical detail',
      closeDetails: 'Close detail',
    }
  : {
      title: 'Proyectos destacados',
      moreExperience: 'Ver más experiencia',
      problem: 'Problema',
      technicalDecisions: 'Decisiones técnicas',
      proves: 'Qué demuestra',
      stack: 'Stack',
      links: 'Links',
      viewDetails: 'Ver detalle técnico',
      closeDetails: 'Cerrar detalle',
    };

const detailSections = currentLang === 'en'
  ? ([
      { key: 'context', label: 'Context' },
      { key: 'frontendArchitecture', label: 'Frontend architecture' },
      { key: 'stateManagement', label: 'State management' },
      { key: 'componentDesign', label: 'Component design' },
      { key: 'uxDecisions', label: 'UX decisions' },
      { key: 'improvementsNext', label: 'What I would improve next' },
    ] as const)
  : ([
      { key: 'context', label: 'Contexto' },
      { key: 'frontendArchitecture', label: 'Arquitectura frontend' },
      { key: 'stateManagement', label: 'Manejo de estado' },
      { key: 'componentDesign', label: 'Diseño de componentes' },
      { key: 'uxDecisions', label: 'Decisiones UX' },
      { key: 'improvementsNext', label: 'Qué mejoraría después' },
    ] as const);

const tagStyles = {
  React: { class: 'bg-[#1e2127] text-white', icon: React },
  TypeScript: { class: 'bg-[#003159] text-white', icon: TypeScript },
  'Tailwind CSS': { class: 'bg-[#09a6c1] text-white', icon: Tailwind },
  'Vue 3': { class: 'bg-[#42b883] text-white', icon: null },
  Vite: { class: 'bg-[#646CFF] text-white', icon: null },
  AppContext: { class: 'bg-emerald-700 text-white', icon: null },
  'Mobile-first UI': { class: 'bg-emerald-600 text-white', icon: null },
  'Composition API': { class: 'bg-emerald-700 text-white', icon: null },
  'Discriminated unions': { class: 'bg-sky-700 text-white', icon: null },
  'Pragmatic DnD': { class: 'bg-violet-700 text-white', icon: null },
  localStorage: { class: 'bg-slate-700 text-white', icon: null },
  'Framer Motion': { class: 'bg-fuchsia-700 text-white', icon: null },
};

const accentBadgeStyles = {
  emerald: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-500/10 dark:text-emerald-300',
  slate: 'bg-slate-100 text-slate-800 dark:bg-slate-500/10 dark:text-slate-200',
  blue: 'bg-blue-100 text-blue-800 dark:bg-blue-500/10 dark:text-blue-300',
};

const projectVisuals: Record<string, { image: string; imageAlt: { es: string; en: string } }> = {
  FitLog: {
    image: '/projects/fitlog.jpg',
    imageAlt: {
      es: 'Vista previa de FitLog como nutrition tracker mobile-first',
      en: 'Preview of FitLog as a mobile-first nutrition tracker',
    },
  },
  'Dashboard Assistant': {
    image: '/projects/dashboard_assistant.webp',
    imageAlt: {
      es: 'Vista previa de Dashboard Assistant embebido en un dashboard',
      en: 'Preview of Dashboard Assistant embedded in a dashboard',
    },
  },
  Kalanban: {
    image: '/projects/kalanban.webp',
    imageAlt: {
      es: 'Vista previa de Kalanban como tablero tipo kanban',
      en: 'Preview of Kalanban as a kanban-style board',
    },
  },
};

const createProjectId = (name: string) =>
  `featured-project-${name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
      {ui.title}
    </h3>
    <a href="#experience-timeline" class="inline-flex items-center gap-2 text-sm font-medium text-emerald-700 transition hover:text-emerald-600 dark:text-emerald-300">
      {ui.moreExperience}
      <span aria-hidden="true">→</span>
    </a>
  </div>

  <div class="grid gap-4 xl:grid-cols-3">
    {
      content.featuredProjects.map((project) => {
        const visual = projectVisuals[project.name];
        const hasCode = Boolean(project.links.code && project.links.code !== '#');
        const hasPreview = Boolean(project.links.preview && project.links.preview !== '#');
        const hasStatus = Boolean(project.status);
        const accent = accentBadgeStyles[project.accent ?? 'slate'];
        const modalId = createProjectId(project.name);

        return (
          <article class="flex h-full flex-col rounded-[1.4rem] border border-slate-200/70 bg-white/90 p-3 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:hover:shadow-none">
            {visual && (
              <div class="overflow-hidden rounded-[1rem] border border-slate-200/70 bg-slate-950/5 dark:border-white/10">
                <img
                  src={visual.image}
                  alt={visual.imageAlt[currentLang]}
                  width="1200"
                  height="760"
                  loading="lazy"
                  class="aspect-[16/10] w-full object-cover object-top"
                />
              </div>
            )}

            <div class="flex flex-1 flex-col gap-4 px-1 pb-1 pt-4">
              <div class="space-y-3">
                <span class={`inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${accent}`}>
                  {project.type}
                </span>

                <h4 class="text-lg font-semibold tracking-tight text-slate-950 dark:text-white">{project.name}</h4>
              </div>

              <div class="space-y-3">
                <section>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.problem}</p>
                  <p class="mt-1.5 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.problem}</p>
                </section>

                <section>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.technicalDecisions}</p>
                  <ul class="mt-1.5 space-y-1.5 text-sm leading-6 text-slate-600 dark:text-slate-300">
                    {project.decisions.slice(0, 2).map((item) => (
                      <li class="flex items-start gap-2.5">
                        <span class="mt-2 size-1.5 shrink-0 rounded-full bg-slate-400 dark:bg-slate-500"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </section>

                <section>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.proves}</p>
                  <p class="mt-1.5 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.role}</p>
                </section>
              </div>

              <section class="space-y-2">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.stack}</p>
                <ul class="flex flex-wrap gap-2">
                  {project.stack.map((item) => {
                    const tag = tagStyles[item as keyof typeof tagStyles] || { class: 'bg-slate-700 text-white', icon: null };
                    const Icon = tag.icon;
                    return (
                      <li>
                        <span class={`flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium ${tag.class}`}>
                          {Icon && <Icon class="size-4" />}
                          {item}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </section>

              <div class="mt-auto space-y-2 pt-1">
                {hasStatus && (
                  <span class="relative inline-flex w-fit overflow-hidden rounded-xl p-[1px]">
                    <span class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,rgba(251,191,36,0)_0%,rgba(251,191,36,0.85)_18%,rgba(245,158,11,0.2)_38%,rgba(251,191,36,0)_62%,rgba(251,191,36,0.85)_82%,rgba(251,191,36,0)_100%)] opacity-80 motion-reduce:animate-none"></span>
                    <span class="relative inline-flex items-center rounded-[0.7rem] bg-amber-50 px-3 py-2 text-sm font-medium text-amber-800 dark:bg-[#0b1120] dark:text-amber-200">
                      {project.status}
                    </span>
                  </span>
                )}
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.links}</p>
                <div class="flex flex-wrap gap-2">
                  {hasCode && (
                    <a
                      href={project.links.code}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
                    >
                      <GitHub class="size-4" />
                      {content.labels.code}
                    </a>
                  )}
                  {hasPreview && (
                    <a
                      href={project.links.preview}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
                    >
                      <Link class="size-4" />
                      {content.labels.preview}
                    </a>
                  )}
                  <button
                    type="button"
                    data-project-modal-trigger={modalId}
                    class="inline-flex items-center rounded-xl bg-slate-950 px-3 py-2 text-sm font-medium text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200"
                  >
                    {ui.viewDetails}
                  </button>
                </div>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>

  {
    content.featuredProjects.map((project) => {
      const modalId = createProjectId(project.name);
      const accent = accentBadgeStyles[project.accent ?? 'slate'];

      return (
        <div id={modalId} class="fixed inset-0 z-50 hidden" data-project-modal>
          <div class="absolute inset-0 bg-slate-950/60 opacity-0 backdrop-blur-sm transition-opacity duration-200" data-project-modal-backdrop></div>
          <div class="relative z-10 flex min-h-full items-end justify-center p-3 sm:items-center sm:p-6">
            <section
              role="dialog"
              aria-modal="true"
              aria-labelledby={`${modalId}-title`}
              class="max-h-[min(88vh,760px)] w-full max-w-3xl translate-y-4 scale-[0.98] overflow-hidden rounded-[1.35rem] border border-slate-200 bg-white opacity-0 shadow-2xl shadow-slate-950/20 transition duration-200 dark:border-white/10 dark:bg-[#0b1120] dark:shadow-slate-950/50"
              data-project-modal-panel
            >
              <div class="flex items-start justify-between gap-4 border-b border-slate-200/70 p-5 dark:border-white/10 sm:p-6">
                <div class="space-y-3">
                  <span class={`inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${accent}`}>
                    {project.type}
                  </span>
                  <div>
                    <h4 id={`${modalId}-title`} class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">{project.name}</h4>
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600 dark:text-slate-300">{project.summary}</p>
                  </div>
                </div>

                <button
                  type="button"
                  data-project-modal-close
                  aria-label={ui.closeDetails}
                  class="inline-flex size-10 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-2xl leading-none text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-200 dark:hover:text-white"
                >
                  <span aria-hidden="true">×</span>
                </button>
              </div>

              <div class="max-h-[calc(88vh-11rem)] overflow-y-auto px-5 py-2 sm:px-6">
                {detailSections.map((section) => (
                  <section class="border-b border-slate-200/70 py-4 last:border-b-0 dark:border-white/10">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{section.label}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.detail[section.key]}</p>
                  </section>
                ))}
              </div>
            </section>
          </div>
        </div>
      );
    })
  }
</div>

<style>
  [data-project-modal].is-visible {
    display: block;
  }

  [data-project-modal].is-open [data-project-modal-backdrop] {
    opacity: 1;
  }

  [data-project-modal].is-open [data-project-modal-panel] {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script is:inline>
  const initFeaturedProjectModals = () => {
    const triggers = document.querySelectorAll('[data-project-modal-trigger]');
    const modals = document.querySelectorAll('[data-project-modal]');
    window.featuredProjectModalState = window.featuredProjectModalState || {
      activeModal: null,
      activeTrigger: null,
      previousBodyOverflow: '',
      keydownBound: false,
    };

    const state = window.featuredProjectModalState;

    const focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';

    const getFocusable = (modal) => Array.from(modal.querySelectorAll(focusableSelector));

    const closeModal = () => {
      if (!state.activeModal) return;

      const modal = state.activeModal;
      modal.classList.remove('is-open');
      document.body.style.overflow = state.previousBodyOverflow;

      window.setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('is-visible');
      }, 200);

      state.activeTrigger?.focus();
      state.activeModal = null;
      state.activeTrigger = null;
    };

    const openModal = (modalId, trigger) => {
      const modal = document.getElementById(modalId);
      if (!modal) return;

      state.activeModal = modal;
      state.activeTrigger = trigger;
      state.previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      modal.classList.remove('hidden');
      modal.classList.add('is-visible');

      window.requestAnimationFrame(() => {
        modal.classList.add('is-open');
      });

      const closeButton = modal.querySelector('[data-project-modal-close]');
      closeButton?.focus();
    };

    triggers.forEach((trigger) => {
      if (trigger.dataset.bound === 'true') return;
      trigger.dataset.bound = 'true';

      trigger.addEventListener('click', () => {
        const modalId = trigger.getAttribute('data-project-modal-trigger');
        if (!modalId) return;
        openModal(modalId, trigger);
      });
    });

    modals.forEach((modal) => {
      if (modal.dataset.bound === 'true') return;
      modal.dataset.bound = 'true';

      modal.querySelectorAll('[data-project-modal-close]').forEach((button) => {
        button.addEventListener('click', closeModal);
      });

      modal.querySelector('[data-project-modal-backdrop]')?.addEventListener('click', closeModal);
    });

    if (state.keydownBound === true) return;
    state.keydownBound = true;

    document.addEventListener('keydown', (event) => {
      if (!state.activeModal) return;

      if (event.key === 'Escape') {
        closeModal();
        return;
      }

      if (event.key !== 'Tab') return;

      const focusable = getFocusable(state.activeModal);
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      }

      if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  };

  if (document.readyState !== 'loading') initFeaturedProjectModals();
  document.addEventListener('DOMContentLoaded', initFeaturedProjectModals, { once: true });
  document.addEventListener('astro:page-load', initFeaturedProjectModals);
</script>
