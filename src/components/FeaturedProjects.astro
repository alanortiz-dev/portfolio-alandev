---
import LinkButton from '@/components/LinkButton.astro';
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;

const accentStyles = {
  emerald: 'bg-white/90 ring-1 ring-emerald-200/70 dark:bg-white/[0.03] dark:ring-emerald-500/20',
  slate: 'bg-white/90 ring-1 ring-slate-200/80 dark:bg-white/[0.03] dark:ring-white/10',
  blue: 'bg-white/90 ring-1 ring-blue-200/70 dark:bg-white/[0.03] dark:ring-blue-500/20',
};
---

<div class="space-y-8">
  {
    content.featuredProjects.map((project) => (
      <article class={`rounded-[2rem] p-6 shadow-sm shadow-slate-200/20 lg:p-8 dark:shadow-none ${accentStyles[project.accent || 'slate']}`}>
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(280px,.95fr)] lg:gap-12">
          <div class="space-y-4">
            <div class="space-y-2">
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
                {content.sectionTitles.featured}
              </p>
              <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white lg:text-3xl">
                {project.name}
              </h3>
              <p class="text-base leading-7 text-slate-600 dark:text-slate-300">{project.summary}</p>
            </div>

            <dl class="grid gap-4 text-sm leading-7 text-slate-600 dark:text-slate-300 md:grid-cols-2">
              <div class="space-y-1">
                <dt class="font-medium text-slate-950 dark:text-white">{content.labels.problem}</dt>
                <dd>{project.problem}</dd>
              </div>
              <div class="space-y-1">
                <dt class="font-medium text-slate-950 dark:text-white">{content.labels.role}</dt>
                <dd>{project.role}</dd>
              </div>
              <div class="space-y-1 md:col-span-2">
                <dt class="font-medium text-slate-950 dark:text-white">{content.labels.architecture}</dt>
                <dd>{project.architecture}</dd>
              </div>
            </dl>
          </div>

          <div class="space-y-5">
            <div>
              <h4 class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
                {content.labels.decisions}
              </h4>
              <ul class="mt-3 space-y-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
                {project.decisions.map((decision) => <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-slate-400 dark:bg-slate-500"></span><span>{decision}</span></li>)}
              </ul>
            </div>

            <div class="rounded-2xl bg-slate-50 p-4 dark:bg-black/20">
              <h4 class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
                {content.labels.impact}
              </h4>
              <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{project.impact}</p>
            </div>

            <div>
              <h4 class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
                {content.labels.stack}
              </h4>
              <ul class="mt-3 flex flex-wrap gap-2">
                {project.stack.map((item) => <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-white/[0.06] dark:text-slate-200">{item}</li>)}
              </ul>
            </div>

            <div class="flex flex-wrap gap-3">
              {project.links.code && <LinkButton href={project.links.code}>{content.labels.code}</LinkButton>}
              {project.links.preview && <LinkButton href={project.links.preview}>{content.labels.preview}</LinkButton>}
            </div>
          </div>
        </div>
      </article>
    ))
  }
</div>
