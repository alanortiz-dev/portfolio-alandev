---
import GitHub from '@/components/icons/GitHub.astro';
import Link from '@/components/icons/Link.astro';
import React from '@/components/icons/React.astro';
import Tailwind from '@/components/icons/Tailwind.astro';
import TypeScript from '@/components/icons/TypeScript.astro';
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const ui = currentLang === 'en'
  ? {
      title: 'Featured projects',
      moreExperience: 'See more experience',
      challenge: 'Challenge',
      proves: 'What it proves',
      whyItMatters: 'Why it matters',
      frontendDecisions: 'Frontend decisions',
    }
  : {
      title: 'Proyectos destacados',
      moreExperience: 'Ver más experiencia',
      challenge: 'Reto',
      proves: 'Qué demuestra',
      whyItMatters: 'Por qué importa',
      frontendDecisions: 'Decisiones frontend',
    };

const tagStyles = {
  React: { class: 'bg-[#1e2127] text-white', icon: React },
  TypeScript: { class: 'bg-[#003159] text-white', icon: TypeScript },
  'Tailwind CSS': { class: 'bg-[#09a6c1] text-white', icon: Tailwind },
  'Vue 3': { class: 'bg-[#42b883] text-white', icon: null },
  Vite: { class: 'bg-[#646CFF] text-white', icon: null },
  AppContext: { class: 'bg-emerald-700 text-white', icon: null },
  'Mobile-first UI': { class: 'bg-emerald-600 text-white', icon: null },
  'Composition API': { class: 'bg-emerald-700 text-white', icon: null },
  'Discriminated unions': { class: 'bg-sky-700 text-white', icon: null },
  'Pragmatic DnD': { class: 'bg-violet-700 text-white', icon: null },
  localStorage: { class: 'bg-slate-700 text-white', icon: null },
  'Framer Motion': { class: 'bg-fuchsia-700 text-white', icon: null },
};

const accentBadgeStyles = {
  emerald: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-500/10 dark:text-emerald-300',
  slate: 'bg-slate-100 text-slate-800 dark:bg-slate-500/10 dark:text-slate-200',
  blue: 'bg-blue-100 text-blue-800 dark:bg-blue-500/10 dark:text-blue-300',
};

const projectVisuals: Record<string, { image: string; imageAlt: { es: string; en: string } }> = {
  FitLog: {
    image: '/projects/fitlog.jpg',
    imageAlt: {
      es: 'Vista previa de FitLog como nutrition tracker mobile-first',
      en: 'Preview of FitLog as a mobile-first nutrition tracker',
    },
  },
  'Dashboard Assistant': {
    image: '/projects/dashboard_assistant.webp',
    imageAlt: {
      es: 'Vista previa de Dashboard Assistant embebido en un dashboard',
      en: 'Preview of Dashboard Assistant embedded in a dashboard',
    },
  },
  Kalanban: {
    image: '/projects/kalanban.webp',
    imageAlt: {
      es: 'Vista previa de Kalanban como tablero tipo kanban',
      en: 'Preview of Kalanban as a kanban-style board',
    },
  },
};
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
      {ui.title}
    </h3>
    <a href="#experience-timeline" class="inline-flex items-center gap-2 text-sm font-medium text-emerald-700 transition hover:text-emerald-600 dark:text-emerald-300">
      {ui.moreExperience}
      <span aria-hidden="true">→</span>
    </a>
  </div>

  <div class="grid gap-4 xl:grid-cols-3">
    {
      content.featuredProjects.map((project) => {
        const visual = projectVisuals[project.name];
        const hasCode = Boolean(project.links.code && project.links.code !== '#');
        const hasPreview = Boolean(project.links.preview && project.links.preview !== '#');
        const accent = accentBadgeStyles[project.accent ?? 'slate'];

        return (
          <article class="rounded-[1.4rem] border border-slate-200/70 bg-white/90 p-3 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/20 dark:border-white/8 dark:bg-white/[0.03] dark:hover:shadow-none">
            <div class="space-y-4">
              {visual && (
                <div class="overflow-hidden rounded-[1rem] border border-slate-200/70 bg-slate-950/5 dark:border-white/8">
                  <img
                    src={visual.image}
                    alt={visual.imageAlt[currentLang]}
                    width="1200"
                    height="760"
                    loading="lazy"
                    class="aspect-[16/10] w-full object-cover object-top"
                  />
                </div>
              )}

              <div class="space-y-4 px-1 pb-1">
                <div class="flex items-start justify-between gap-3">
                  <div class="space-y-3">
                    <span class={`inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${accent}`}>
                      {project.type}
                    </span>

                    <div>
                      <h4 class="text-lg font-semibold tracking-tight text-slate-950 dark:text-white">{project.name}</h4>
                      <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{project.summary}</p>
                    </div>
                  </div>

                  {hasPreview && (
                    <a
                      href={project.links.preview}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex size-9 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-200 dark:hover:text-white"
                    >
                      <Link class="size-4" />
                    </a>
                  )}
                </div>

                <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1 2xl:grid-cols-2">
                  <div class="rounded-[1rem] border border-slate-200/70 bg-slate-50/80 p-3 dark:border-white/10 dark:bg-white/[0.03]">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.challenge}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.problem}</p>
                  </div>
                  <div class="rounded-[1rem] border border-slate-200/70 bg-slate-50/80 p-3 dark:border-white/10 dark:bg-white/[0.03]">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.proves}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.role}</p>
                  </div>
                </div>

                <div class="rounded-[1rem] border border-slate-200/70 bg-white p-3 dark:border-white/10 dark:bg-white/[0.02]">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.whyItMatters}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">{project.impact}</p>
                </div>

                <div class="space-y-2">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.frontendDecisions}</p>
                  <ul class="space-y-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
                    {project.decisions.map((item) => (
                      <li class="flex items-start gap-2.5">
                        <span class="mt-2 size-1.5 shrink-0 rounded-full bg-slate-400 dark:bg-slate-500"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <ul class="flex flex-wrap gap-2">
                  {project.stack.map((item) => {
                    const tag = tagStyles[item as keyof typeof tagStyles] || { class: 'bg-slate-700 text-white', icon: null };
                    const Icon = tag.icon;
                    return (
                      <li>
                        <span class={`flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium ${tag.class}`}>
                          {Icon && <Icon class="size-4" />}
                          {item}
                        </span>
                      </li>
                    );
                  })}
                </ul>

                <div class="flex flex-wrap gap-2 pt-1">
                  {hasCode && (
                    <a
                      href={project.links.code}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
                    >
                      <GitHub class="size-4" />
                      {content.labels.code}
                    </a>
                  )}
                  {hasPreview && (
                    <a
                      href={project.links.preview}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
                    >
                      <Link class="size-4" />
                      {content.labels.preview}
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</div>
