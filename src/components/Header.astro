---
import SettingsIcon from './icons/SettingsIcon.astro';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import { homeContent } from '@/data/homeContent';

const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';
const content = homeContent[currentLang];
const settingsMenuId = 'site-settings-menu';
const cvHref = currentLang === 'en' ? '/docs/Alan_Ortiz_EN.pdf' : '/docs/Alan_Ortiz_ES.pdf';
const cvDownload = currentLang === 'en' ? 'Alan_Ortiz_CV_EN.pdf' : 'Alan_Ortiz_CV_ES.pdf';
const cvLabel = currentLang === 'en' ? 'Download CV' : 'Descargar CV';
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-[#f8fafc]/90 backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/90">
  <nav class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-4 px-1.5 py-4 text-sm text-slate-600 sm:px-2 lg:px-2.5 dark:text-slate-300">
    <a href={currentLang === 'en' ? '/en' : '/es'} class="inline-flex items-center font-semibold tracking-tight text-slate-950 dark:text-white">
      <span class="text-base">Alan Ortiz</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {[
        { label: currentLang === 'en' ? 'Home' : 'Inicio', url: '#top' },
        { label: currentLang === 'en' ? 'About me' : 'Sobre mí', url: '#about' },
        { label: content.nav.featured, url: '#featured-engineering' },
        { label: currentLang === 'en' ? 'Skills' : 'Habilidades', url: '#engineering-principles' },
        { label: content.nav.timeline, url: '#experience-timeline' },
        { label: content.nav.contact, url: 'mailto:alan.omar.ortz@gmail.com' },
      ].map((link, index) => (
        <a
          class={`transition hover:text-slate-950 dark:hover:text-white ${index === 0 ? 'text-slate-950 dark:text-white' : ''}`}
          href={link.url}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={cvHref}
        download={cvDownload}
        class="hidden min-h-9 items-center justify-center rounded-full border border-slate-200/80 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white sm:inline-flex"
      >
        {cvLabel}
        <span aria-hidden="true" class="ml-2">↓</span>
      </a>

      <div class="relative flex items-center gap-2" data-settings-root>
        <button
          type="button"
          data-settings-button
          aria-label={currentLang === 'en' ? 'Open site settings' : 'Abrir ajustes del sitio'}
          aria-expanded="false"
          aria-controls={settingsMenuId}
          class="rounded-full border border-slate-200/80 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-300 dark:hover:bg-white/[0.06] dark:hover:text-white"
        >
          <SettingsIcon class="h-5 w-5" />
        </button>

        <div
          id={settingsMenuId}
          data-settings-menu
          class="absolute right-0 top-12 z-50 hidden w-48 rounded-lg border border-slate-200 bg-white p-1.5 shadow-lg shadow-slate-200/35 dark:border-white/10 dark:bg-slate-900 dark:shadow-slate-950/30"
        >
          <div class="space-y-2">
            <LanguageToggle />
            <div class="h-px bg-slate-200/80 dark:bg-white/10"></div>
            <ThemeToggle />
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  [data-settings-menu].open {
    display: block;
    animation: scale-up-center 0.025s linear both;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.99);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script is:inline>
  (() => {
    const closeAllSettingsMenus = () => {
      document.querySelectorAll('[data-settings-root]').forEach((root) => {
        root.querySelector('[data-settings-menu]')?.classList.remove('open');
        root.querySelector('[data-settings-button]')?.setAttribute('aria-expanded', 'false');
      });
    };

    const initSettingsMenus = () => {
      document.querySelectorAll('[data-settings-root]').forEach((root) => {
        if (root.dataset.settingsBound === 'true') return;
        root.dataset.settingsBound = 'true';

        const btn = root.querySelector('[data-settings-button]');
        const menu = root.querySelector('[data-settings-menu]');

        btn?.addEventListener('click', (event) => {
          event.stopPropagation();
          const isOpen = menu?.classList.contains('open');
          closeAllSettingsMenus();

          if (!isOpen) {
            menu?.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });

        menu?.addEventListener('click', (event) => {
          event.stopPropagation();
        });
      });
    };

    window.__closeSiteSettingsMenus = closeAllSettingsMenus;

    if (!window.__siteSettingsBound) {
      window.__siteSettingsBound = true;

      document.addEventListener('click', () => window.__closeSiteSettingsMenus?.());
      document.addEventListener('site-settings-close', () => window.__closeSiteSettingsMenus?.());
      document.addEventListener('astro:page-load', initSettingsMenus);
      document.addEventListener('astro:after-swap', () => {
        initSettingsMenus();
        window.__closeSiteSettingsMenus?.();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') window.__closeSiteSettingsMenus?.();
      });
    }

    initSettingsMenus();
  })();
</script>
