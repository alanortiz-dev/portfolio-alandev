---
import SettingsIcon from './icons/SettingsIcon.astro';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import { homeContent } from '@/data/homeContent';

const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';
const content = homeContent[currentLang];
const settingsMenuId = 'site-settings-menu';
const cvHref = currentLang === 'en' ? '/docs/Alan_Ortiz_EN.pdf' : '/docs/Alan_Ortiz_ES.pdf';
const cvDownload = currentLang === 'en' ? 'Alan_Ortiz_CV_EN.pdf' : 'Alan_Ortiz_CV_ES.pdf';
const cvLabel = currentLang === 'en' ? 'Download CV' : 'Descargar CV';
---

<header class="sticky top-0 z-50 bg-transparent pt-3 sm:pt-4">
  <nav class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 rounded-[1.35rem] border border-slate-200/70 bg-white/90 px-4 py-3 shadow-sm shadow-slate-200/10 backdrop-blur-xl dark:border-white/10 dark:bg-[#0b1120]/90 dark:shadow-none sm:px-6 lg:px-8">
    <a href={currentLang === 'en' ? '/en' : '/es'} class="inline-flex items-center gap-3 text-sm font-semibold tracking-tight text-slate-950 dark:text-white">
      <span class="inline-flex size-10 items-center justify-center rounded-xl border border-emerald-400/25 bg-emerald-400/10 text-base font-semibold text-emerald-600 dark:text-emerald-300">AO</span>
      <span class="text-base">Alan Ortiz</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {[
        { label: currentLang === 'en' ? 'Home' : 'Inicio', url: '#top' },
        { label: currentLang === 'en' ? 'About me' : 'Sobre mí', url: '#about' },
        { label: content.nav.featured, url: '#featured-engineering' },
        { label: currentLang === 'en' ? 'Skills' : 'Habilidades', url: '#engineering-principles' },
        { label: content.nav.timeline, url: '#experience-timeline' },
        { label: content.nav.contact, url: 'mailto:alan.omar.ortz@gmail.com' },
      ].map((link, index) => (
        <a
          class={`relative text-sm transition hover:text-slate-950 dark:hover:text-white ${index === 0 ? 'text-slate-950 dark:text-white' : ''}`}
          href={link.url}
        >
          {link.label}
          {index === 0 && <span class="absolute -bottom-3 left-1/2 h-0.5 w-10 -translate-x-1/2 rounded-full bg-emerald-400"></span>}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={cvHref}
        download={cvDownload}
        class="hidden min-h-10 items-center justify-center rounded-full border border-emerald-400/20 bg-emerald-400/10 px-4 py-2 text-sm font-medium text-emerald-700 transition hover:bg-emerald-400/20 focus:outline-none focus-visible:ring focus-visible:ring-emerald-300 focus-visible:ring-offset-2 dark:text-emerald-300 sm:inline-flex"
      >
        {cvLabel}
        <span aria-hidden="true" class="ml-2">↓</span>
      </a>

      <div class="relative flex items-center gap-2" data-settings-root>
        <button
          type="button"
          data-settings-button
          aria-label={currentLang === 'en' ? 'Open site settings' : 'Abrir ajustes del sitio'}
          aria-expanded="false"
          aria-controls={settingsMenuId}
          class="rounded-full border border-slate-200 p-2 text-slate-600 transition hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:text-slate-300 dark:hover:text-white"
        >
          <SettingsIcon class="h-5 w-5" />
        </button>

        <div
          id={settingsMenuId}
          data-settings-menu
          class="absolute right-0 top-11 z-50 hidden w-44 rounded-2xl border border-slate-200 bg-white p-2 shadow-lg shadow-slate-200/40 dark:border-white/10 dark:bg-slate-900"
        >
          <LanguageToggle />
          <ThemeToggle />
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  [data-settings-menu].open {
    display: block;
    animation: scale-up-center 0.15s ease-out both;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script is:inline>
  const root = document.querySelector('[data-settings-root]');
  const btn = root?.querySelector('[data-settings-button]');
  const menu = root?.querySelector('[data-settings-menu]');

  const closeMenu = () => {
    menu?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
  };

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = menu?.classList.contains('open');
    if (isOpen) {
      closeMenu();
      return;
    }

    menu?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true');
  });

  document.addEventListener('click', () => closeMenu());
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
  document.addEventListener('astro:after-swap', () => closeMenu());
</script>
