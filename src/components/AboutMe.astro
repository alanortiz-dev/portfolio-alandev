---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<article class="space-y-6 rounded-[2rem] bg-white/70 p-6 shadow-sm shadow-slate-200/10 ring-1 ring-slate-200/60 dark:bg-white/[0.02] dark:ring-white/10 dark:shadow-none lg:p-8">
  <div class="max-w-3xl space-y-5 text-pretty text-base leading-8 text-slate-600 dark:text-slate-300">
    {content.about.map((paragraph) => <p>{paragraph}</p>)}
  </div>
</article>
