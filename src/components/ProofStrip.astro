---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="rounded-[2rem] border border-slate-200/70 bg-white/85 p-5 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:shadow-none">
  <div class="grid gap-4 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-start lg:gap-8">
    <p class="pt-1 text-xs font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
      {content.proofStrip.label}
    </p>
    <ul class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      {content.proofStrip.items.map((item) => <li class="rounded-2xl bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-700 dark:bg-white/[0.04] dark:text-slate-200">{item}</li>)}
    </ul>
  </div>
</div>
