---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
      {content.sectionTitles.principles}
    </h3>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600 dark:text-slate-300">
      {content.sectionTitles.principlesIntro}
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    {
      content.principles.map((principle) => (
        <article class="rounded-[1.4rem] border border-slate-200/70 bg-white/90 p-5 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:hover:shadow-none lg:p-6">
          <h4 class="text-xl font-semibold text-slate-950 dark:text-white">{principle.title}</h4>
          <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{principle.body}</p>
        </article>
      ))
    }
  </div>
</div>
