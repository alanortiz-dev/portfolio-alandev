---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {
    content.principles.map((principle) => (
      <article class="rounded-3xl border border-slate-200/80 bg-white/90 p-6 shadow-sm shadow-slate-200/30 dark:border-white/10 dark:bg-white/[0.03] dark:shadow-none">
        <h3 class="text-xl font-semibold text-slate-950 dark:text-white">{principle.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{principle.body}</p>
      </article>
    ))
  }
</div>
