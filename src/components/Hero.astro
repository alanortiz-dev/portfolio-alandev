---
import Briefcase from '@/components/icons/Briefcase.astro';
import CheckIcon from '@/components/icons/CheckIcon.astro';
import Code from '@/components/icons/Code.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import type { HomeContent } from '@/data/homeContent';
import profile from '@/data/profile';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const highlights = currentLang === 'en'
  ? [
      {
        title: 'Clear interfaces',
        body: 'Reusable components and accessible patterns that improve product clarity.',
        icon: Code,
      },
      {
        title: 'Maintainable code',
        body: 'Scalable architecture with good practices, testing, and solid separation of concerns.',
        icon: CheckIcon,
      },
      {
        title: 'Ready for production',
        body: 'Built with performance, quality, and real delivery in mind.',
        icon: Briefcase,
      },
    ]
  : [
      {
        title: 'Interfaces claras',
        body: 'Componentes reutilizables y accesibles que mejoran la UX.',
        icon: Code,
      },
      {
        title: 'Código mantenible',
        body: 'Arquitectura escalable con buenas prácticas y pruebas.',
        icon: CheckIcon,
      },
      {
        title: 'Listas para producción',
        body: 'Orientadas a rendimiento, calidad y negocio.',
        icon: Briefcase,
      },
    ];

const specialties = currentLang === 'en'
  ? [
      'Frontend systems with React, Vue.js and TypeScript',
      'Reusable components and design systems',
      'API integrations and backend-connected flows',
      'Performance, testing and accessibility',
      'E-commerce, fintech and automation',
    ]
  : [
      'Desarrollo de interfaces con React, Vue.js y TypeScript',
      'Componentes reutilizables y design systems',
      'Integraciones con APIs y servicios backend',
      'Performance, testing y accesibilidad',
      'E-commerce, fintech y automatización',
    ];

const technologies = [
  { name: 'React', kind: 'react' },
  { name: 'Vue.js', kind: 'vue' },
  { name: 'TypeScript', kind: 'ts' },
  { name: 'Next.js', kind: 'next' },
  { name: 'Tailwind CSS', kind: 'tailwind' },
  { name: 'Node.js', kind: 'node' },
  { name: 'HTML5', kind: 'html' },
  { name: 'CSS3', kind: 'css' },
  { name: 'SASS', kind: 'sass' },
  { name: 'Git', kind: 'git' },
  { name: 'Jest', kind: 'jest' },
  { name: 'Docker', kind: 'docker' },
] as const;

const profileMeta = [
  { kind: 'location', value: content.hero.location },
  { kind: 'stack', value: content.hero.metrics[0]?.value || '' },
  { kind: 'domain', value: content.hero.metrics[1]?.value || '' },
].filter((item) => item.value);
---

<section class="space-y-6">
  <div class="rounded-[2rem] border border-slate-200/70 bg-white/95 px-5 py-5 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0a1020]/95 dark:shadow-none sm:px-6 sm:py-6 lg:px-8 lg:py-8">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.48fr)_320px] lg:items-start xl:grid-cols-[minmax(0,1.54fr)_336px] xl:gap-10">
      <div class="space-y-8">
        <div class="inline-flex items-center rounded-full border border-emerald-400/20 bg-emerald-400/8 px-3 py-1 text-[12px] font-medium text-emerald-700 dark:text-emerald-300">
          Frontend Engineer
        </div>

        <div class="space-y-5">
          <h1 class="max-w-[9ch] text-[2.5rem] font-semibold leading-[0.96] tracking-[-0.05em] text-slate-950 sm:text-[3.35rem] lg:text-[4.2rem] dark:text-white">
            {
              currentLang === 'en' ? (
                <>
                  <span class="block">I build product</span>
                  <span class="block">interfaces that are</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">clear</span>, <span class="text-emerald-600 dark:text-[#67e4a6]">maintainable</span>,</span>
                  <span class="block">and <span class="text-emerald-600 dark:text-[#67e4a6]">ready for</span></span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">production</span>.</span>
                </>
              ) : (
                <>
                  <span class="block">Construyo</span>
                  <span class="block">interfaces de</span>
                  <span class="block">producto <span class="text-emerald-600 dark:text-[#67e4a6]">claras,</span></span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">mantenibles</span> y</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">listas para</span></span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">producción</span>.</span>
                </>
              )
            }
          </h1>

          <p class="max-w-[39rem] text-[15px] leading-7 text-slate-600 sm:text-[1.02rem] sm:leading-8 dark:text-slate-300">
            {content.hero.description}
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-3">
          {highlights.map((item) => {
            const Icon = item.icon;
            return (
              <article class="space-y-2.5">
                <div class="flex items-center gap-3">
                  <span class="inline-flex size-8 items-center justify-center rounded-full border border-emerald-400/10 bg-emerald-400/8 text-emerald-500 dark:text-emerald-300">
                    <Icon class="size-4" />
                  </span>
                  <h2 class="text-sm font-semibold text-slate-950 dark:text-white">{item.title}</h2>
                </div>
                <p class="max-w-[16ch] pl-11 text-sm leading-6 text-slate-600 dark:text-slate-400">{item.body}</p>
              </article>
            );
          })}
        </div>

        <nav class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="#featured-engineering"
            class="inline-flex min-h-10 items-center justify-center rounded-2xl bg-emerald-400 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-300 focus:outline-none focus-visible:ring focus-visible:ring-emerald-300 focus-visible:ring-offset-2"
          >
            {content.hero.primaryCta}
            <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4.5 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
          >
            <MailIcon class="size-4" aria-hidden="true" />
            {currentLang === 'en' ? 'Contact' : 'Contactar'}
          </a>
        </nav>
      </div>

      <aside class="w-full max-w-[320px] justify-self-end rounded-[1.7rem] border border-slate-200/70 bg-white/92 px-5 py-6 dark:border-white/10 dark:bg-[#121a2d] sm:px-6 lg:mt-6 lg:px-6 lg:py-7 xl:mt-8">
        <div class="flex h-full flex-col justify-between gap-6 text-center">
          <div class="space-y-5">
            <div class="mx-auto inline-flex rounded-full bg-[radial-gradient(circle_at_30%_30%,#7090ff_0%,#5879ff_45%,#4164ff_100%)] p-2 shadow-[0_16px_36px_rgba(65,100,255,0.18)]">
              <img
                class="size-20 rounded-full object-cover sm:size-24"
                src={profile.avatar}
                alt={`Portrait of ${profile.name}`}
                width="96"
                height="96"
                loading="eager"
                fetchpriority="high"
              />
            </div>

            <div>
              <h2 class="text-[1.9rem] font-semibold tracking-tight text-slate-950 dark:text-white">{profile.name}</h2>
              <p class="mt-1 text-sm text-emerald-700 dark:text-emerald-300">Frontend / Product Engineer</p>
            </div>

            <div class="mx-auto max-w-[240px] space-y-3.5 text-left text-sm text-slate-600 dark:text-slate-300">
              {profileMeta.map((item) => (
                <p class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center text-emerald-500 dark:text-emerald-300">
                    {item.kind === 'location' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z" />
                        <circle cx="12" cy="11" r="2.2" />
                      </svg>
                    )}
                    {item.kind === 'stack' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="4" y="5" width="16" height="5" rx="1.5" />
                        <rect x="4" y="14" width="16" height="5" rx="1.5" />
                      </svg>
                    )}
                    {item.kind === 'domain' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="5" y="4" width="14" height="16" rx="2" />
                        <path d="M8 8h8M8 12h8M8 16h5" />
                      </svg>
                    )}
                  </span>
                  <span>{item.value}</span>
                </p>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2.5">
            <a
              href={profile.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <GitHub class="size-4" aria-hidden="true" />
              GitHub
            </a>
            <a
              href={`${profile.social.linkedin}?locale=${currentLang === 'en' ? 'en_US' : 'es_ES'}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <LinkedInIcon class="size-4" aria-hidden="true" />
              LinkedIn
            </a>
            <a
              href={`mailto:${profile.email}`}
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <MailIcon class="size-4" aria-hidden="true" />
              Email
            </a>
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-8 grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.08fr)] xl:grid-cols-[minmax(0,1fr)_minmax(0,1.12fr)]">
      <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 dark:border-white/10 dark:bg-[#121a2d] sm:p-6">
        <h2 class="text-xl font-semibold text-slate-950 dark:text-white">{currentLang === 'en' ? 'Specialties' : 'Especialidades'}</h2>
        <ul class="mt-5 grid gap-3">
          {specialties.map((item) => (
            <li class="flex items-center gap-3 rounded-[1.05rem] border border-slate-200/70 bg-slate-50/75 px-4 py-3 text-sm text-slate-600 dark:border-white/10 dark:bg-white/[0.02] dark:text-slate-300">
              <span class="inline-flex size-5 shrink-0 items-center justify-center rounded-full border border-emerald-400/10 bg-emerald-400/8 text-emerald-400">
                <CheckIcon class="size-3.5" />
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 dark:border-white/10 dark:bg-[#121a2d] sm:p-6">
        <h2 class="text-xl font-semibold text-slate-950 dark:text-white">{currentLang === 'en' ? 'Technologies' : 'Tecnologías'}</h2>
        <div class="mt-5 grid grid-cols-3 gap-3 sm:grid-cols-4 xl:grid-cols-6">
          {technologies.map((item) => (
            <div class="flex min-h-[96px] flex-col items-center justify-center gap-2 rounded-[1.1rem] border border-slate-200/70 bg-slate-50/75 px-3 py-4 text-center dark:border-white/10 dark:bg-white/[0.02]">
              <span class={`tech-mark tech-${item.kind}`} aria-hidden="true">{item.name}</span>
              <span class="text-xs font-medium text-slate-600 dark:text-slate-300">{item.name}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .tech-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.65rem;
    height: 2.65rem;
    border-radius: 9999px;
    font-size: 0;
    position: relative;
    background: rgba(15, 23, 42, 0.08);
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.18);
  }

  .dark .tech-mark {
    background: rgba(255, 255, 255, 0.04);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .tech-mark::before {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .tech-react::before { content: '⚛'; color: #61dafb; }
  .tech-vue::before { content: 'V'; color: #42b883; }
  .tech-ts::before { content: 'TS'; color: #3178c6; }
  .tech-next::before { content: 'N'; color: currentColor; }
  .tech-tailwind::before { content: '~'; color: #38bdf8; font-size: 1.4rem; }
  .tech-node::before { content: '⬢'; color: #68a063; font-size: 1.15rem; }
  .tech-html::before { content: '5'; color: #e34f26; }
  .tech-css::before { content: '3'; color: #1572b6; }
  .tech-sass::before { content: 'S'; color: #cc6699; }
  .tech-git::before { content: '◆'; color: #f05032; font-size: 1.1rem; }
  .tech-jest::before { content: 'J'; color: #99425b; }
  .tech-docker::before { content: '🐳'; font-size: 1rem; }
</style>
