---
import Briefcase from '@/components/icons/Briefcase.astro';
import CheckIcon from '@/components/icons/CheckIcon.astro';
import Code from '@/components/icons/Code.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import NextJS from '@/components/icons/NextJS.astro';
import ReactIcon from '@/components/icons/React.astro';
import Tailwind from '@/components/icons/Tailwind.astro';
import TypeScript from '@/components/icons/TypeScript.astro';
import type { HomeContent } from '@/data/homeContent';
import profile from '@/data/profile';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const highlights = currentLang === 'en'
  ? [
      {
        title: 'Clear interfaces',
        body: 'Reusable components and accessible patterns that improve product clarity.',
        icon: Code,
      },
      {
        title: 'Maintainable code',
        body: 'Scalable architecture with good practices, testing, and solid separation of concerns.',
        icon: CheckIcon,
      },
      {
        title: 'Ready for production',
        body: 'Built with performance, quality, and real delivery in mind.',
        icon: Briefcase,
      },
    ]
  : [
      {
        title: 'Interfaces claras',
        body: 'Componentes reutilizables y accesibles que mejoran la UX.',
        icon: Code,
      },
      {
        title: 'Código mantenible',
        body: 'Arquitectura escalable con buenas prácticas y pruebas.',
        icon: CheckIcon,
      },
      {
        title: 'Listas para producción',
        body: 'Orientadas a rendimiento, calidad y negocio.',
        icon: Briefcase,
      },
    ];

const specialties = currentLang === 'en'
  ? [
      'Frontend systems with React, Vue.js and TypeScript',
      'Reusable components and design systems',
      'API integrations and backend-connected flows',
      'Performance, testing and accessibility',
      'E-commerce, fintech and automation',
    ]
  : [
      'Desarrollo de interfaces con React, Vue.js y TypeScript',
      'Componentes reutilizables y design systems',
      'Integraciones con APIs y servicios backend',
      'Performance, testing y accesibilidad',
      'E-commerce, fintech y automatización',
    ];

const technologies = [
  { name: 'React', kind: 'react', icon: ReactIcon },
  { name: 'Vue.js', kind: 'vue', icon: null },
  { name: 'TypeScript', kind: 'ts', icon: TypeScript },
  { name: 'Next.js', kind: 'next', icon: NextJS },
  { name: 'Tailwind CSS', kind: 'tailwind', icon: Tailwind },
  { name: 'Node.js', kind: 'node', icon: null },
  { name: 'HTML5', kind: 'html', icon: null },
  { name: 'CSS3', kind: 'css', icon: null },
  { name: 'SASS', kind: 'sass', icon: null },
  { name: 'Git', kind: 'git', icon: null },
  { name: 'Jest', kind: 'jest', icon: null },
  { name: 'Docker', kind: 'docker', icon: null },
] as const;

const profileMeta = [
  { kind: 'location', value: content.hero.location },
  { kind: 'stack', value: content.hero.metrics[0]?.value || '' },
  { kind: 'domain', value: content.hero.metrics[1]?.value || '' },
].filter((item) => item.value);
---

<section class="space-y-6 lg:space-y-7">
  <div class="rounded-[2rem] border border-slate-200/70 bg-white/95 px-5 py-6 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0a1020]/95 dark:shadow-none sm:px-6 sm:py-7 lg:px-8 lg:py-8 xl:px-9 xl:py-9">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_350px] lg:items-start xl:grid-cols-[minmax(0,1.4fr)_360px] xl:gap-10">
      <div class="space-y-8">
        <div class="inline-flex items-center rounded-full border border-emerald-400/20 bg-emerald-400/8 px-3 py-1 text-[12px] font-medium text-emerald-700 dark:text-emerald-300">
          Frontend Engineer
        </div>

        <div class="space-y-5">
          <h1 class="max-w-[15ch] text-[1.75rem] font-semibold leading-[0.95] tracking-[-0.055em] text-slate-950 sm:text-[2.3rem] lg:max-w-[17ch] lg:text-[2.85rem] dark:text-white">
            {
              currentLang === 'en' ? (
                <>
                  <span class="block">I build product</span>
                  <span class="block">interfaces that are</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">clear</span>, <span class="text-emerald-600 dark:text-[#67e4a6]">maintainable</span>,</span>
                  <span class="block">and <span class="text-emerald-600 dark:text-[#67e4a6]">ready for</span></span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">production</span>.</span>
                </>
              ) : (
                <>
                  <span class="block">Construyo interfaces de</span>
                  <span class="block">producto <span class="text-emerald-600 dark:text-[#67e4a6]">claras,</span></span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">mantenibles</span> y</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">listas para producción</span>.</span>
                </>
              )
            }
          </h1>

          <p class="max-w-[40rem] text-[15px] leading-7 text-slate-600 sm:text-[1.08rem] sm:leading-8 dark:text-slate-300">
            {content.hero.description}
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-3">
          {highlights.map((item) => {
            const Icon = item.icon;
            return (
              <article class="space-y-2.5">
                <div class="flex items-center gap-2">
                  <span class="inline-flex size-7 items-center justify-center rounded-full border border-emerald-400/10 bg-emerald-400/8 text-emerald-500 dark:text-emerald-300">
                    <Icon class="size-3.5" />
                  </span>
                  <h2 class="text-sm font-semibold text-slate-950 dark:text-white">{item.title}</h2>
                </div>
                <p class="max-w-[24ch] pl-5 text-sm leading-6 text-slate-600 dark:text-slate-400">{item.body}</p>
              </article>
            );
          })}
        </div>

        <nav class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="#featured-engineering"
            class="inline-flex min-h-10 items-center justify-center rounded-2xl bg-emerald-400 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-300 focus:outline-none focus-visible:ring focus-visible:ring-emerald-300 focus-visible:ring-offset-2"
          >
            {content.hero.primaryCta}
            <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex min-h-10 min-w-[8.5rem] items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4.5 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
          >
            <MailIcon class="size-4" aria-hidden="true" />
            {currentLang === 'en' ? 'Contact' : 'Contactar'}
          </a>
        </nav>
      </div>

      <aside class="w-full max-w-[350px] justify-self-end rounded-[1.7rem] border border-slate-200/70 bg-white/92 px-5 py-6 dark:border-white/10 dark:bg-[#121a2d] sm:px-6 lg:mt-1 lg:px-6 lg:py-7 xl:mt-1">
        <div class="flex h-full flex-col justify-between gap-6 text-center">
          <div class="space-y-5">
            <div class="mx-auto inline-flex rounded-full bg-[radial-gradient(circle_at_30%_30%,#7090ff_0%,#5879ff_45%,#4164ff_100%)] p-2 shadow-[0_16px_36px_rgba(65,100,255,0.18)]">
              <img
                class="size-24 rounded-full object-cover"
                src={profile.avatar}
                alt={`Portrait of ${profile.name}`}
                width="96"
                height="96"
                loading="eager"
                fetchpriority="high"
              />
            </div>

            <div>
              <h2 class="text-[2rem] font-semibold tracking-tight text-slate-950 dark:text-white">{profile.name}</h2>
              <p class="mt-1 text-sm text-emerald-700 dark:text-emerald-300">Frontend / Product Engineer</p>
            </div>

            <div class="mx-auto max-w-[240px] space-y-3.5 text-left text-sm text-slate-600 dark:text-slate-300">
              {profileMeta.map((item) => (
                <p class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center text-emerald-500 dark:text-emerald-300">
                    {item.kind === 'location' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z" />
                        <circle cx="12" cy="11" r="2.2" />
                      </svg>
                    )}
                    {item.kind === 'stack' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="4" y="5" width="16" height="5" rx="1.5" />
                        <rect x="4" y="14" width="16" height="5" rx="1.5" />
                      </svg>
                    )}
                    {item.kind === 'domain' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="5" y="4" width="14" height="16" rx="2" />
                        <path d="M8 8h8M8 12h8M8 16h5" />
                      </svg>
                    )}
                  </span>
                  <span>{item.value}</span>
                </p>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2.5">
            <a
              href={profile.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <GitHub class="size-4" aria-hidden="true" />
              GitHub
            </a>
            <a
              href={`${profile.social.linkedin}?locale=${currentLang === 'en' ? 'en_US' : 'es_ES'}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <LinkedInIcon class="size-4" aria-hidden="true" />
              LinkedIn
            </a>
            <a
              href={`mailto:${profile.email}`}
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <MailIcon class="size-4" aria-hidden="true" />
              Email
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.08fr)] xl:grid-cols-[minmax(0,1fr)_minmax(0,1.12fr)]">
    <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 shadow-sm shadow-slate-200/12 dark:border-white/10 dark:bg-[#121a2d] dark:shadow-none sm:p-6">
      <h2 class="text-[1.4rem] font-semibold tracking-tight text-slate-950 dark:text-white">{currentLang === 'en' ? 'Specialties' : 'Especialidades'}</h2>
      <ul class="mt-5 space-y-0">
        {specialties.map((item) => (
          <li class="flex items-center gap-3 border-b border-slate-200/70 py-3.5 text-[0.96rem] text-slate-600 last:border-b-0 dark:border-white/10 dark:text-slate-300">
            <span class="inline-flex size-5 shrink-0 items-center justify-center text-emerald-400">
              <CheckIcon class="size-4" />
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 shadow-sm shadow-slate-200/12 dark:border-white/10 dark:bg-[#121a2d] dark:shadow-none sm:p-6">
      <h2 class="text-[1.4rem] font-semibold tracking-tight text-slate-950 dark:text-white">{currentLang === 'en' ? 'Technologies' : 'Tecnologías'}</h2>
      <div class="mt-6 grid grid-cols-3 gap-x-5 gap-y-6 sm:grid-cols-4 xl:grid-cols-6">
        {technologies.map((item) => {
          const Icon = item.icon;
          return (
            <div class="flex flex-col items-center gap-2 text-center">
              <span class={`tech-mark tech-${item.kind}`} aria-hidden="true">
                {Icon ? <Icon class="size-8" /> : item.name}
              </span>
              <span class="text-sm font-medium text-slate-600 dark:text-slate-300">{item.name}</span>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</section>

<style>
  .tech-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 9999px;
    color: white;
    font-size: 0;
    position: relative;
  }

  .tech-mark :global(svg) {
    width: 1.9rem;
    height: 1.9rem;
  }

  .tech-vue,
  .tech-node,
  .tech-html,
  .tech-css,
  .tech-sass,
  .tech-git,
  .tech-jest,
  .tech-docker {
    background: transparent;
  }

  .tech-mark::before {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .tech-react { color: #61dafb; }
  .tech-vue::before { content: 'V'; color: #42b883; }
  .tech-ts { color: #3178c6; }
  .tech-next { color: white; }
  .tech-tailwind { color: #38bdf8; }
  .tech-node::before { content: '⬢'; color: #68a063; font-size: 1.2rem; }
  .tech-html::before { content: '5'; color: #e34f26; }
  .tech-css::before { content: '3'; color: #1572b6; }
  .tech-sass::before { content: 'S'; color: #cc6699; }
  .tech-git::before { content: '◆'; color: #f05032; font-size: 1.15rem; }
  .tech-jest::before { content: 'J'; color: #99425b; }
  .tech-docker::before { content: '🐳'; font-size: 1.05rem; }
</style>
