---
import Badge from '@/components/Badge.astro';
import Briefcase from '@/components/icons/Briefcase.astro';
import CheckIcon from '@/components/icons/CheckIcon.astro';
import Code from '@/components/icons/Code.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import type { HomeContent } from '@/data/homeContent';
import profile from '@/data/profile';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';
const cvLink = {
  href: currentLang === 'en' ? '/docs/Alan_Ortiz_EN.pdf' : '/docs/Alan_Ortiz_ES.pdf',
  download: currentLang === 'en' ? 'Alan_Ortiz_CV_EN.pdf' : 'Alan_Ortiz_CV_ES.pdf',
  label: currentLang === 'en' ? 'Download CV' : 'Descargar CV',
};

const highlights = currentLang === 'en'
  ? [
      {
        title: 'Clear interfaces',
        body: 'Reusable components and accessible UX patterns that improve clarity.',
        icon: Code,
      },
      {
        title: 'Maintainable code',
        body: 'Scalable frontend structure with sound practices, testing, and separation of concerns.',
        icon: CheckIcon,
      },
      {
        title: 'Ready for production',
        body: 'Built with performance, product quality, and real delivery in mind.',
        icon: Briefcase,
      },
    ]
  : [
      {
        title: 'Interfaces claras',
        body: 'Componentes reutilizables y patrones accesibles que mejoran la UX.',
        icon: Code,
      },
      {
        title: 'Código mantenible',
        body: 'Arquitectura frontend escalable con buenas prácticas, testing y separación de responsabilidades.',
        icon: CheckIcon,
      },
      {
        title: 'Listas para producción',
        body: 'Pensadas para performance, calidad de producto y entrega real.',
        icon: Briefcase,
      },
    ];

const specialties = currentLang === 'en'
  ? [
      'Frontend systems with React, Vue.js and TypeScript',
      'Reusable components and design systems',
      'API integrations and backend-connected flows',
      'Performance, testing and accessibility',
      'E-commerce, fintech and automation',
    ]
  : [
      'Desarrollo de interfaces con React, Vue.js y TypeScript',
      'Componentes reutilizables y design systems',
      'Integraciones con APIs y servicios backend',
      'Performance, testing y accesibilidad',
      'E-commerce, fintech y automatización',
    ];

const technologies = [
  { name: 'React', kind: 'react' },
  { name: 'Vue.js', kind: 'vue' },
  { name: 'TypeScript', kind: 'ts' },
  { name: 'Next.js', kind: 'next' },
  { name: 'Tailwind CSS', kind: 'tailwind' },
  { name: 'Node.js', kind: 'node' },
  { name: 'HTML5', kind: 'html' },
  { name: 'CSS3', kind: 'css' },
  { name: 'SASS', kind: 'sass' },
  { name: 'Git', kind: 'git' },
  { name: 'Jest', kind: 'jest' },
  { name: 'Docker', kind: 'docker' },
] as const;

const profileMeta = [
  { icon: '⌖', value: content.hero.location },
  { icon: '⌘', value: content.hero.metrics[0]?.value || '' },
  { icon: '◫', value: content.hero.metrics[1]?.value || '' },
].filter((item) => item.value);
---

<section class="space-y-5">
  <div class="rounded-[2rem] border border-slate-200/70 bg-white/95 p-3 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-4">
    <div class="grid gap-5 rounded-[1.6rem] border border-slate-200/70 bg-white/90 p-5 dark:border-white/5 dark:bg-[#0b1324] sm:p-7 lg:grid-cols-[minmax(0,1.38fr)_360px] lg:gap-8 lg:p-8 xl:p-9">
      <div class="space-y-7 lg:space-y-8">
        <div class="space-y-5">
          <Badge>{currentLang === 'en' ? 'Frontend Engineer' : 'Frontend Engineer'}</Badge>
          <h1 class="max-w-[11.5ch] text-[2.45rem] font-semibold leading-[0.96] tracking-[-0.045em] text-slate-950 sm:text-[3.35rem] lg:text-[4rem] dark:text-white">
            {content.hero.title}
          </h1>
          <p class="max-w-[38rem] text-[15px] leading-7 text-slate-600 sm:text-[1.05rem] sm:leading-8 dark:text-slate-300">
            {content.hero.description}
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3 sm:gap-5">
          {highlights.map((item) => {
            const Icon = item.icon;
            return (
              <article class="space-y-2.5 px-1">
                <span class="inline-flex size-8 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 dark:text-emerald-300">
                  <Icon class="size-4" />
                </span>
                <h2 class="text-sm font-semibold text-slate-950 dark:text-white">{item.title}</h2>
                <p class="max-w-[18ch] text-sm leading-6 text-slate-600 dark:text-slate-400">{item.body}</p>
              </article>
            );
          })}
        </div>

        <nav class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="#featured-engineering"
            class="inline-flex min-h-11 items-center justify-center rounded-full bg-emerald-400 px-5 py-2.5 text-sm font-medium text-slate-950 transition hover:bg-emerald-300 focus:outline-none focus-visible:ring focus-visible:ring-emerald-300 focus-visible:ring-offset-2"
          >
            {content.hero.primaryCta}
            <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
          >
            <MailIcon class="size-4" aria-hidden="true" />
            {currentLang === 'en' ? 'Contact' : 'Contactar'}
          </a>
        </nav>
      </div>

      <aside class="rounded-[1.7rem] border border-slate-200/70 bg-white/90 px-5 py-6 dark:border-white/8 dark:bg-[#11192d] sm:px-6 lg:px-7 lg:py-7">
        <div class="flex h-full flex-col justify-between gap-6 text-center">
          <div class="space-y-5">
            <img
              class="mx-auto size-24 rounded-full object-cover ring-4 ring-emerald-500/15 sm:size-28"
              src={profile.avatar}
              alt={`Portrait of ${profile.name}`}
              width="112"
              height="112"
              loading="eager"
              fetchpriority="high"
            />

            <div>
              <h2 class="text-[1.95rem] font-semibold tracking-tight text-slate-950 dark:text-white">{profile.name}</h2>
              <p class="mt-1 text-sm text-emerald-700 dark:text-emerald-300">Frontend / Product Engineer</p>
            </div>

            <div class="space-y-3.5 text-sm text-slate-600 dark:text-slate-300">
              {profileMeta.map((item) => (
                <p class="flex items-center justify-center gap-2.5 text-center">
                  <span class="text-[0.95rem] text-emerald-500 dark:text-emerald-300">{item.icon}</span>
                  <span>{item.value}</span>
                </p>
              ))}
            </div>
          </div>

          <div class="grid gap-3">
            <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-3">
              <a
                href={profile.social.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-11 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
              >
                <GitHub class="size-4" aria-hidden="true" />
                GitHub
              </a>
              <a
                href={`${profile.social.linkedin}?locale=${currentLang === 'en' ? 'en_US' : 'es_ES'}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-11 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
              >
                <LinkedInIcon class="size-4" aria-hidden="true" />
                LinkedIn
              </a>
              <a
                href={`mailto:${profile.email}`}
                class="inline-flex min-h-11 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
              >
                <MailIcon class="size-4" aria-hidden="true" />
                Email
              </a>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,.95fr)_minmax(0,1.05fr)]">
      <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/90 p-5 dark:border-white/8 dark:bg-[#0c1426] sm:p-6">
        <h2 class="text-xl font-semibold text-slate-950 dark:text-white">{currentLang === 'en' ? 'Specialties' : 'Especialidades'}</h2>
        <ul class="mt-4 space-y-1.5">
          {specialties.map((item) => (
            <li class="flex items-center gap-3 rounded-xl border-b border-slate-200/70 py-3 text-sm text-slate-600 last:border-b-0 dark:border-white/8 dark:text-slate-300">
              <span class="inline-flex size-5 shrink-0 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-400">
                <CheckIcon class="size-3.5" />
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/90 p-5 dark:border-white/8 dark:bg-[#0c1426] sm:p-6">
        <h2 class="text-xl font-semibold text-slate-950 dark:text-white">{currentLang === 'en' ? 'Technologies' : 'Tecnologías'}</h2>
        <div class="mt-5 grid grid-cols-3 gap-4 sm:grid-cols-4 lg:grid-cols-6">
          {technologies.map((item) => (
            <div class="flex flex-col items-center gap-2 rounded-2xl border border-slate-200/60 bg-slate-50/70 px-3 py-4 text-center dark:border-white/8 dark:bg-white/[0.02]">
              <span class={`tech-mark tech-${item.kind}`} aria-hidden="true">{item.name}</span>
              <span class="text-xs font-medium text-slate-600 dark:text-slate-300">{item.name}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .tech-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    font-size: 0;
    position: relative;
    background: rgba(15, 23, 42, 0.08);
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.18);
  }

  .dark .tech-mark {
    background: rgba(255, 255, 255, 0.04);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .tech-mark::before {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .tech-react::before { content: '⚛'; color: #61dafb; }
  .tech-vue::before { content: 'V'; color: #42b883; }
  .tech-ts::before { content: 'TS'; color: #3178c6; }
  .tech-next::before { content: 'N'; color: currentColor; }
  .tech-tailwind::before { content: '~'; color: #38bdf8; font-size: 1.4rem; }
  .tech-node::before { content: '⬢'; color: #68a063; font-size: 1.15rem; }
  .tech-html::before { content: '5'; color: #e34f26; }
  .tech-css::before { content: '3'; color: #1572b6; }
  .tech-sass::before { content: 'S'; color: #cc6699; }
  .tech-git::before { content: '◆'; color: #f05032; font-size: 1.1rem; }
  .tech-jest::before { content: 'J'; color: #99425b; }
  .tech-docker::before { content: '🐳'; font-size: 1rem; }
</style>
