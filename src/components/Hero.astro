---
import CheckIcon from '@/components/icons/CheckIcon.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import type { HomeContent } from '@/data/homeContent';
import profile from '@/data/profile';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const proofCards = content.hero.metrics.slice(0, 3);

const specialties = currentLang === 'en'
  ? [
      'React, Vue.js and TypeScript for product interfaces',
      'Reusable components and consistent UI patterns',
      'REST API and GraphQL integrations',
      'Performance, accessibility and responsive UI',
      'Testing with Playwright, PHPUnit and Selenium',
      'Fullstack context with Node.js, PHP, Laravel, Symfony and SQL',
    ]
  : [
      'React, Vue.js y TypeScript para interfaces de producto',
      'Componentes reutilizables y patrones de UI consistentes',
      'Integraciones con REST APIs y GraphQL',
      'Performance, accesibilidad y responsive UI',
      'Testing con Playwright, PHPUnit y Selenium',
      'Contexto fullstack con Node.js, PHP, Laravel, Symfony y SQL',
    ];

const technologies = [
  { name: 'React', icon: '/icons/tech/react.svg' },
  { name: 'TypeScript', icon: '/icons/tech/typescript.svg' },
  { name: 'JavaScript', icon: '/icons/tech/javascript.svg' },
  { name: 'REST APIs', icon: '/icons/tech/rest-apis.svg' },
  { name: 'GraphQL', icon: '/icons/tech/graphql.svg' },
  { name: 'Vue.js', icon: '/icons/tech/vue.svg' },
  { name: 'Tailwind CSS', icon: '/icons/tech/tailwindcss.svg' },
  { name: 'Playwright', icon: '/icons/tech/playwright.svg' },
  { name: 'Node.js', icon: '/icons/tech/nodejs.svg' },
  { name: 'PHP', icon: '/icons/tech/php.svg' },
  { name: 'Git', icon: '/icons/tech/git.svg' },
  { name: currentLang === 'en' ? 'Responsive UI' : 'UI responsive', icon: '/icons/tech/responsive-ui.svg' },
];

const profileMeta = currentLang === 'en'
  ? [
      { kind: 'location', value: content.hero.location },
      { kind: 'stack', value: 'React · Vue.js · TypeScript' },
      { kind: 'domain', value: 'E-commerce · Fintech · Internal tools' },
    ]
  : [
      { kind: 'location', value: content.hero.location },
      { kind: 'stack', value: 'React · Vue.js · TypeScript' },
      { kind: 'domain', value: 'E-commerce · Fintech · Herramientas internas' },
    ];
---

<section class="space-y-6 lg:space-y-7">
  <div class="rounded-[2rem] border border-slate-200/70 bg-white/95 px-5 py-6 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0a1020]/95 dark:shadow-none sm:px-6 sm:py-7 lg:px-8 lg:py-8 xl:px-9 xl:py-9">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_350px] lg:items-start xl:grid-cols-[minmax(0,1.4fr)_360px] xl:gap-10">
      <div class="contents lg:order-1 lg:block lg:space-y-8">
        <span class="relative order-1 inline-flex w-full overflow-hidden rounded-full p-[1px] lg:w-fit">
          <span class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,rgba(52,211,153,0)_0%,rgba(52,211,153,0.75)_18%,rgba(16,185,129,0.2)_38%,rgba(52,211,153,0)_62%,rgba(52,211,153,0.75)_82%,rgba(52,211,153,0)_100%)] opacity-70 motion-reduce:animate-none"></span>
          <span class="relative inline-flex w-full items-center justify-center rounded-full bg-emerald-50 px-4 py-1.5 text-center text-sm font-medium text-emerald-700 dark:bg-[#0a1020] dark:text-emerald-300 lg:w-auto lg:justify-start lg:text-left">
            {content.hero.eyebrow}
          </span>
        </span>

        <div class="order-3 space-y-5">
          <h1 class="max-w-[18rem] text-[1.75rem] font-semibold leading-[0.95] tracking-normal text-slate-950 sm:max-w-[34rem] sm:text-[2.3rem] lg:max-w-[42rem] lg:text-[2.85rem] dark:text-white">
            {
              currentLang === 'en' ? (
                <>
                  <span class="block">I build <span class="text-emerald-600 dark:text-[#67e4a6]">frontend</span></span>
                  <span class="block">interfaces that are clear, fast</span>
                  <span class="block">and <span class="text-emerald-600 dark:text-[#67e4a6]">maintainable</span>.</span>
                </>
              ) : (
                <>
                  <span class="block">Construyo interfaces</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">frontend</span> claras, rápidas y</span>
                  <span class="block"><span class="text-emerald-600 dark:text-[#67e4a6]">fáciles de mantener</span>.</span>
                </>
              )
            }
          </h1>

          <p class="max-w-[40rem] text-[15px] leading-7 text-slate-600 sm:text-[1.08rem] sm:leading-8 dark:text-slate-300">
            {content.hero.description}
          </p>
        </div>

        <div class="order-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {proofCards.map((item, index) => (
            <article class={`rounded-[1.35rem] border border-slate-200/70 bg-slate-50/80 p-4 shadow-sm shadow-slate-200/15 dark:border-white/10 dark:bg-white/[0.03] dark:shadow-none sm:p-5 ${index === 2 ? 'md:col-span-2 xl:col-span-1' : ''}`}>
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-emerald-700 dark:text-emerald-300">{item.label}</p>
              <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">{item.value}</p>
            </article>
          ))}
        </div>

        <nav class="order-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="#featured-engineering"
            class="inline-flex min-h-10 items-center justify-center rounded-2xl bg-emerald-400 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-300 focus:outline-none focus-visible:ring focus-visible:ring-emerald-300 focus-visible:ring-offset-2"
          >
            {content.hero.primaryCta}
            <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex min-h-10 min-w-[8.5rem] items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4.5 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
          >
            <MailIcon class="size-4" aria-hidden="true" />
            {currentLang === 'en' ? 'Contact' : 'Contactar'}
          </a>
        </nav>
      </div>

      <aside class="order-2 w-full max-w-none justify-self-stretch rounded-[1.7rem] border border-slate-200/70 bg-white/92 px-5 py-6 dark:border-white/10 dark:bg-[#121a2d] sm:px-6 lg:order-2 lg:mt-1 lg:max-w-[350px] lg:justify-self-end lg:px-6 lg:py-7 xl:mt-1">
        <div class="flex h-full flex-col justify-between gap-6 text-center">
          <div class="space-y-5">
            <div class="mx-auto inline-flex rounded-full bg-[radial-gradient(circle_at_30%_30%,#7090ff_0%,#5879ff_45%,#4164ff_100%)] p-2 shadow-[0_16px_36px_rgba(65,100,255,0.18)]">
              <img
                class="size-24 rounded-full object-cover"
                src={profile.avatar}
                alt={`Portrait of ${profile.name}`}
                width="96"
                height="96"
                loading="eager"
                fetchpriority="high"
              />
            </div>

            <div>
              <h2 class="text-[2rem] font-semibold tracking-tight text-slate-950 dark:text-white">{profile.name}</h2>
              <p class="mt-1 text-sm text-emerald-700 dark:text-emerald-300">Frontend Engineer</p>
            </div>

            <div class="mx-auto max-w-[240px] space-y-3.5 text-left text-sm text-slate-600 dark:text-slate-300">
              {profileMeta.map((item) => (
                <p class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center text-emerald-500 dark:text-emerald-300">
                    {item.kind === 'location' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z" />
                        <circle cx="12" cy="11" r="2.2" />
                      </svg>
                    )}
                    {item.kind === 'stack' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="4" y="5" width="16" height="5" rx="1.5" />
                        <rect x="4" y="14" width="16" height="5" rx="1.5" />
                      </svg>
                    )}
                    {item.kind === 'domain' && (
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect x="5" y="4" width="14" height="16" rx="2" />
                        <path d="M8 8h8M8 12h8M8 16h5" />
                      </svg>
                    )}
                  </span>
                  <span>{item.value}</span>
                </p>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2.5">
            <a
              href={profile.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <GitHub class="size-4" aria-hidden="true" />
              GitHub
            </a>
            <a
              href={`${profile.social.linkedin}?locale=${currentLang === 'en' ? 'en_US' : 'es_ES'}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <LinkedInIcon class="size-4" aria-hidden="true" />
              LinkedIn
            </a>
            <a
              href={`mailto:${profile.email}`}
              class="inline-flex min-h-10 items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
            >
              <MailIcon class="size-4" aria-hidden="true" />
              Email
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.08fr)] xl:grid-cols-[minmax(0,1fr)_minmax(0,1.12fr)]">
    <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 shadow-sm shadow-slate-200/12 dark:border-white/10 dark:bg-[#121a2d] dark:shadow-none sm:p-6">
      <h2 class="text-[1.4rem] font-semibold tracking-tight text-slate-950 dark:text-white">{currentLang === 'en' ? 'How I contribute as a frontend engineer' : 'Cómo aporto como frontend'}</h2>
      <ul class="mt-3 space-y-0">
        {specialties.map((item) => (
          <li class="flex items-center gap-2.5 border-b border-slate-200/70 py-2 text-sm text-slate-600 last:border-b-0 dark:border-white/10 dark:text-slate-300">
            <span class="inline-flex size-4 shrink-0 items-center justify-center text-emerald-400">
              <CheckIcon class="size-3.5" />
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="rounded-[1.6rem] border border-slate-200/70 bg-white/92 p-5 shadow-sm shadow-slate-200/12 dark:border-white/10 dark:bg-[#121a2d] dark:shadow-none sm:p-6">
      <h2 class="text-[1.4rem] font-semibold tracking-tight text-slate-950 dark:text-white">{currentLang === 'en' ? 'Technologies' : 'Tecnologías'}</h2>
      <div class="mt-3 grid grid-cols-3 gap-x-2 gap-y-4 sm:grid-cols-4 xl:grid-cols-5">
        {technologies.map((item) => (
          <div class="flex flex-col items-center gap-1.5 text-center">
            <span class="tech-mark" aria-hidden="true">
              <img class="tech-icon" src={item.icon} alt="" loading="lazy" />
            </span>
            <span class="text-xs font-medium leading-tight text-slate-600 dark:text-slate-300">{item.name}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</section>

<style>
  .tech-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.45rem;
    height: 2.45rem;
    border-radius: 9999px;
    position: relative;
    background: rgba(15, 23, 42, 0.04);
  }

  :global(.dark) .tech-mark {
    background: rgba(255, 255, 255, 0.06);
  }

  .tech-icon {
    width: 1.55rem;
    height: 1.55rem;
    object-fit: contain;
    display: block;
  }
</style>
