---
import Badge from '@/components/Badge.astro';
import DocumentIcon from '@/components/icons/DocumentIcon.astro';
import LinkedInIcon from '@/components/icons/LinkedIn.astro';
import MailIcon from '@/components/icons/Mail.astro';
import SocialPill from '@/components/SocialPill.astro';
import type { HomeContent } from '@/data/homeContent';
import profile from '@/data/profile';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = Astro.currentLocale || 'es';
const cvLink = {
  href: currentLang === 'en' ? '/docs/Alan_Ortiz_EN.pdf' : '/docs/Alan_Ortiz_ES.pdf',
  download: currentLang === 'en' ? 'Alan_Ortiz_CV_EN.pdf' : 'Alan_Ortiz_CV_ES.pdf',
  label: currentLang === 'en' ? 'Download resume' : 'Descargar CV',
};
---

<section class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(360px,.85fr)] lg:items-center lg:gap-14 xl:gap-20">
  <div class="space-y-5 sm:space-y-6 lg:space-y-7">
    <div class="flex items-center gap-3 sm:gap-4">
      <img
        class="size-14 rounded-full object-cover shadow-lg ring-4 ring-white dark:ring-slate-900 sm:size-16"
        src={profile.avatar}
        alt={`Portrait of ${profile.name}`}
        width="64"
        height="64"
        loading="eager"
        fetchpriority="high"
      />
      <div class="min-w-0 max-w-full overflow-hidden">
        <Badge>{content.hero.eyebrow}</Badge>
      </div>
    </div>

    <div class="space-y-4 sm:space-y-5">
      <h1 class="max-w-[11ch] text-3xl font-semibold leading-[0.98] tracking-tight text-slate-950 sm:max-w-[13ch] sm:text-5xl xl:text-6xl dark:text-white">
        {content.hero.title}
      </h1>
      <p class="max-w-2xl text-[15px] leading-7 text-slate-600 sm:text-lg sm:leading-8 dark:text-slate-300">
        {content.hero.description}
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-2.5 text-sm text-slate-600 dark:text-slate-300 sm:gap-3">
      <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 dark:border-white/10 dark:bg-white/5">
        {content.labels.basedIn}: {content.hero.location}
      </span>
      <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 leading-5 text-emerald-700 dark:border-emerald-500/20 dark:bg-emerald-500/10 dark:text-emerald-300">
        {content.hero.status}
      </span>
    </div>

    <nav class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <a href="#featured-engineering" class="inline-flex min-h-11 w-full items-center justify-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-slate-800 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 sm:w-auto dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
        {content.hero.primaryCta}
      </a>
      <SocialPill href={`mailto:${profile.email}`} class="w-full justify-center sm:w-auto">
        <MailIcon class="size-4" aria-hidden="true" />
        {currentLang === 'en' ? 'Contact' : 'Contacto'}
      </SocialPill>
    </nav>
  </div>

  <aside>
    <article class="rounded-[2rem] border border-slate-200/80 bg-white/90 p-5 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:shadow-none sm:p-6 lg:p-7">
      <div class="space-y-4 sm:space-y-5">
        <div>
          <h2 class="text-2xl font-semibold text-slate-950 dark:text-white">{profile.name}</h2>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">Frontend / Product Engineer</p>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{profile.address}</p>
        </div>

        <div class="space-y-2 text-sm text-slate-600 dark:text-slate-300">
          {content.hero.metrics.map((metric) => (
            <p>{metric.value}</p>
          ))}
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <a
            href={cvLink.href}
            download={cvLink.download}
            class="inline-flex min-h-12 items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
          >
            <span class="inline-flex items-center gap-2">
              <DocumentIcon class="size-4" aria-hidden="true" />
              {cvLink.label}
            </span>
            <span aria-hidden="true">↘</span>
          </a>
          <a
            href={`${profile.social.linkedin}?locale=${currentLang === 'en' ? 'en_US' : 'es_ES'}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-800 transition hover:border-slate-300 hover:bg-slate-100 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-100 dark:hover:bg-white/[0.08]"
          >
            <span class="inline-flex items-center gap-2">
              <LinkedInIcon class="size-4" aria-hidden="true" />
              LinkedIn
            </span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </article>
  </aside>
</section>
