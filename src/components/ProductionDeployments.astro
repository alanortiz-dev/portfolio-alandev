---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {
    content.deployments.map((deployment) => (
      <article class="rounded-3xl border border-slate-200/80 bg-white/90 p-6 shadow-sm shadow-slate-200/30 dark:border-white/10 dark:bg-white/[0.03] dark:shadow-none">
        <div class="space-y-4">
          <div>
            <h3 class="text-xl font-semibold text-slate-950 dark:text-white">{deployment.name}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{deployment.summary}</p>
          </div>

          <ul class="flex flex-wrap gap-2">
            {deployment.focus.map((item) => <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-200">{item}</li>)}
          </ul>

          <a
            href={deployment.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-900 hover:text-slate-600 dark:text-white dark:hover:text-slate-300"
          >
            {content.labels.visitSite}
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </article>
    ))
  }
</div>
