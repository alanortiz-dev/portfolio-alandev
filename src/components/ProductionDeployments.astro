---
import Link from '@/components/icons/Link.astro';
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';

const ui = currentLang === 'en'
  ? {
      previous: 'Previous production site',
      next: 'Next production site',
    }
  : {
      previous: 'Sitio anterior',
      next: 'Siguiente sitio',
    };

const deploymentVisuals: Record<
  string,
  {
    image: string;
    width: number;
    height: number;
    imageAlt: { es: string; en: string };
  }
> = {
  'Tatuajes en Valencia': {
    image: '/sites/tatuajes-en-valencia.webp',
    width: 1200,
    height: 648,
    imageAlt: {
      es: 'Vista previa del sitio Tatuajes en Valencia',
      en: 'Preview of the Tatuajes en Valencia website',
    },
  },
  'Hivora Clothes': {
    image: '/sites/hivora-clothes.webp',
    width: 1200,
    height: 630,
    imageAlt: {
      es: 'Vista previa del sitio Hivora Clothes',
      en: 'Preview of the Hivora Clothes website',
    },
  },
  'Spark Creative House': {
    image: '/sites/spark-creative-house.webp',
    width: 1200,
    height: 616,
    imageAlt: {
      es: 'Vista previa del sitio Spark Creative House',
      en: 'Preview of the Spark Creative House website',
    },
  },
  'Pia Maria Coaching': {
    image: '/sites/pia-maria-coaching.webp',
    width: 1200,
    height: 650,
    imageAlt: {
      es: 'Vista previa del sitio Pia Maria Coaching',
      en: 'Preview of the Pia Maria Coaching website',
    },
  },
};
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div class="min-w-0 flex-1">
      <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
        {content.sectionTitles.deployments}
      </h3>
      <p class="mt-3 max-w-6xl text-sm leading-6 text-slate-600 dark:text-slate-300">
        {content.sectionTitles.deploymentsIntro}
      </p>
    </div>

    <div class="hidden shrink-0 gap-2 md:flex" aria-hidden="false">
      <button
        type="button"
        data-production-carousel-control="-1"
        aria-label={ui.previous}
        class="inline-flex size-9 items-center justify-center rounded-full border border-slate-200 bg-white text-lg leading-none text-slate-700 transition hover:border-slate-300 hover:text-slate-950 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-slate-200 disabled:hover:text-slate-700 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white dark:disabled:hover:bg-white/[0.03] dark:disabled:hover:text-slate-200"
      >
        <span aria-hidden="true">←</span>
      </button>
      <button
        type="button"
        data-production-carousel-control="1"
        aria-label={ui.next}
        class="inline-flex size-9 items-center justify-center rounded-full border border-slate-200 bg-white text-lg leading-none text-slate-700 transition hover:border-slate-300 hover:text-slate-950 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-slate-200 disabled:hover:text-slate-700 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white dark:disabled:hover:bg-white/[0.03] dark:disabled:hover:text-slate-200"
      >
        <span aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <div
    class="production-carousel -mx-1 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-1 pb-2"
    data-production-carousel
  >
    {
      content.deployments.map((deployment) => {
        const visual = deploymentVisuals[deployment.name];
        const displayUrl = deployment.url;

        return (
          <article class="flex min-w-[82vw] max-w-[82vw] snap-start rounded-[1.2rem] border border-slate-200/70 bg-white/90 p-3 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:hover:shadow-none sm:min-w-[320px] sm:max-w-[320px] md:min-w-[360px] md:max-w-[360px] lg:min-w-[410px] lg:max-w-[410px]">
            <div class="flex h-full w-full flex-col gap-3">
              <div>
                <h4 class="text-base font-semibold text-slate-950 dark:text-white">{deployment.name}</h4>
                {deployment.category && (
                  <p class="mt-1 text-sm font-medium leading-5 text-emerald-700 dark:text-emerald-300">{deployment.category}</p>
                )}
              </div>

              {visual && (
                <a
                  href={deployment.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block overflow-hidden rounded-[0.9rem] border border-slate-200/70 bg-slate-950/5 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03]"
                  aria-label={`${content.labels.visitSite}: ${deployment.name} (${currentLang === 'en' ? 'opens in a new tab' : 'abre en una nueva pestaña'})`}
                >
                  <div class="flex h-7 items-center gap-1.5 border-b border-slate-200/70 bg-white/85 px-2.5 dark:border-white/10 dark:bg-white/[0.04]">
                    <span class="size-2 rounded-full bg-red-400/80"></span>
                    <span class="size-2 rounded-full bg-amber-400/80"></span>
                    <span class="size-2 rounded-full bg-emerald-400/80"></span>
                    <span class="ml-1 truncate text-[11px] text-slate-500 dark:text-slate-400">{displayUrl}</span>
                  </div>
                  <img
                    src={visual.image}
                    alt={visual.imageAlt[currentLang]}
                    width={visual.width}
                    height={visual.height}
                    loading="lazy"
                    decoding="async"
                    class="aspect-[16/9] w-full object-cover object-top transition duration-300 group-hover:scale-[1.02]"
                  />
                </a>
              )}

              <div class="space-y-2">
                <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">{deployment.summary}</p>
                {deployment.description && (
                  <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">{deployment.description}</p>
                )}
              </div>

              <div class="mt-auto space-y-3">
                <ul class="flex flex-wrap gap-2">
                  {deployment.focus.map((item) => (
                    <li class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-medium text-slate-700 dark:bg-white/[0.06] dark:text-slate-200">{item}</li>
                  ))}
                </ul>

                <a
                  href={deployment.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex w-fit items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
                  aria-label={`${content.labels.visitSite}: ${deployment.name} (${currentLang === 'en' ? 'opens in a new tab' : 'abre en una nueva pestaña'})`}
                >
                  <Link class="size-4" />
                  {content.labels.visitSite}
                </a>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>

  <div class="mt-4 grid grid-cols-2 gap-2 md:hidden">
    <button
      type="button"
      data-production-carousel-control="-1"
      aria-label={ui.previous}
      class="inline-flex min-h-11 items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-45 disabled:active:scale-100 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200"
    >
      <span aria-hidden="true">←</span>
      {ui.previous}
    </button>
    <button
      type="button"
      data-production-carousel-control="1"
      aria-label={ui.next}
      class="inline-flex min-h-11 items-center justify-center gap-2 rounded-xl bg-slate-950 px-4 py-2 text-sm font-medium text-white transition active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-45 disabled:active:scale-100 focus:outline-none focus-visible:ring focus-visible:ring-slate-400 focus-visible:ring-offset-2 dark:bg-white dark:text-slate-950"
    >
      {ui.next}
      <span aria-hidden="true">→</span>
    </button>
  </div>
</div>

<style>
  .production-carousel {
    scrollbar-width: thin;
    scrollbar-color: rgb(148 163 184 / 0.6) transparent;
  }

  .production-carousel::-webkit-scrollbar {
    height: 8px;
  }

  .production-carousel::-webkit-scrollbar-track {
    background: transparent;
  }

  .production-carousel::-webkit-scrollbar-thumb {
    background: rgb(148 163 184 / 0.45);
    border-radius: 999px;
  }
</style>

<script is:inline>
  const initProductionCarousel = () => {
    const carousel = document.querySelector('[data-production-carousel]');
    const controls = document.querySelectorAll('[data-production-carousel-control]');

    if (!carousel || controls.length === 0 || carousel.dataset.bound === 'true') return;
    carousel.dataset.bound = 'true';

    const getCards = () => Array.from(carousel.querySelectorAll('article'));

    const getCurrentIndex = () => {
      const cards = getCards();
      if (cards.length === 0) return 0;

      const firstCard = cards[0];
      const secondCard = cards[1];
      const step = secondCard ? secondCard.offsetLeft - firstCard.offsetLeft : firstCard.getBoundingClientRect().width;

      return Math.min(cards.length - 1, Math.max(0, Math.round(carousel.scrollLeft / step)));
    };

    const updateControls = () => {
      const currentIndex = getCurrentIndex();
      const lastIndex = getCards().length - 1;

      controls.forEach((button) => {
        const direction = Number(button.getAttribute('data-production-carousel-control')) || 1;
        button.disabled = direction < 0 ? currentIndex === 0 : currentIndex >= lastIndex;
      });
    };

    const scrollCarousel = (direction) => {
      const cards = getCards();
      if (cards.length === 0) return;

      const currentIndex = getCurrentIndex();
      const targetIndex = Math.min(cards.length - 1, Math.max(0, currentIndex + direction));

      if (targetIndex === currentIndex) return;

      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      const targetLeft = Math.min(cards[targetIndex].offsetLeft - carousel.offsetLeft, maxScroll);

      carousel.scrollTo({
        left: targetLeft,
        behavior: 'smooth',
      });
    };

    controls.forEach((button) => {
      const direction = Number(button.getAttribute('data-production-carousel-control')) || 1;
      button.addEventListener('click', () => scrollCarousel(direction));
    });

    carousel.addEventListener('scroll', updateControls, { passive: true });
    window.addEventListener('resize', updateControls);
    updateControls();
  };

  if (document.readyState !== 'loading') initProductionCarousel();
  document.addEventListener('DOMContentLoaded', initProductionCarousel, { once: true });
  document.addEventListener('astro:page-load', initProductionCarousel);
</script>
