---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {
    content.deployments.map((deployment) => (
      <article class="rounded-[2rem] bg-white/90 p-6 shadow-sm shadow-slate-200/20 ring-1 ring-slate-200/70 dark:bg-white/[0.03] dark:ring-white/10 dark:shadow-none lg:p-7">
        <div class="space-y-5">
          <div>
            <h3 class="text-xl font-semibold text-slate-950 dark:text-white">{deployment.name}</h3>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{deployment.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{deployment.summary}</p>
          </div>

          <ul class="flex flex-wrap gap-2">
            {deployment.focus.map((item) => <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-white/[0.06] dark:text-slate-200">{item}</li>)}
          </ul>

          <a
            href={deployment.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-900 hover:text-slate-600 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:text-white dark:hover:text-slate-300"
            aria-label={`${content.labels.visitSite}: ${deployment.name} (${Astro.currentLocale === 'en' ? 'opens in a new tab' : 'abre en una nueva pestaña'})`}
          >
            {content.labels.visitSite}
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </article>
    ))
  }
</div>
