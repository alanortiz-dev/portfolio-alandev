---
import Link from '@/components/icons/Link.astro';
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
      {content.sectionTitles.deployments}
    </h3>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600 dark:text-slate-300">
      {content.sectionTitles.deploymentsIntro}
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    {
      content.deployments.map((deployment) => (
        <article class="rounded-[1.4rem] border border-slate-200/70 bg-white/90 p-5 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/20 dark:border-white/10 dark:bg-white/[0.03] dark:hover:shadow-none lg:p-6">
          <div class="space-y-5">
            <div>
              <h4 class="text-xl font-semibold text-slate-950 dark:text-white">{deployment.name}</h4>
              <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{deployment.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</p>
              <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{deployment.summary}</p>
            </div>

            <ul class="flex flex-wrap gap-2">
              {deployment.focus.map((item) => <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-white/[0.06] dark:text-slate-200">{item}</li>)}
            </ul>

            <a
              href={deployment.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
              aria-label={`${content.labels.visitSite}: ${deployment.name} (${Astro.currentLocale === 'en' ? 'opens in a new tab' : 'abre en una nueva pestaña'})`}
            >
              <Link class="size-4" />
              {content.labels.visitSite}
            </a>
          </div>
        </article>
      ))
    }
  </div>
</div>
