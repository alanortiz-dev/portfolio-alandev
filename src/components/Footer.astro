---
import profile from '@/data/profile';

const currentYear = new Date().getFullYear();
const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';
---

<footer class="mt-16 border-t border-slate-200/80 dark:border-white/10">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-4 py-5 text-sm text-slate-600 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8 dark:text-slate-300">
    <p>© {currentYear} Alan Ortiz</p>

    <nav class="flex flex-wrap items-center gap-4">
      <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="transition hover:text-slate-950 dark:hover:text-white">GitHub</a>
      <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="transition hover:text-slate-950 dark:hover:text-white">LinkedIn</a>
      <a href="mailto:alan.omar.ortz@gmail.com" class="transition hover:text-slate-950 dark:hover:text-white">{currentLang === 'en' ? 'Contact' : 'Contacto'}</a>
    </nav>
  </div>
</footer>
