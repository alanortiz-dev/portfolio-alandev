---
import type { HomeContent } from '@/data/homeContent';
import ExperienceItem from './ExperienceItem.astro';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
---

<div class="rounded-[1.75rem] border border-slate-200/70 bg-white/95 p-4 shadow-sm shadow-slate-200/20 dark:border-white/10 dark:bg-[#0b1120]/95 dark:shadow-none sm:p-5">
  <div class="mb-5">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
      {content.sectionTitles.timeline}
    </h3>
    <p class="mt-3 max-w-5xl text-sm leading-6 text-slate-600 dark:text-slate-300">
      {content.sectionTitles.timelineIntro}
    </p>
  </div>

  <div class="space-y-5">
    {
      content.experiences.map((exp, index) => (
        <ExperienceItem
          index={index}
          role={exp.role}
          company={exp.company}
          summary={exp.summary}
          link={exp.link}
          period={exp.period}
          location={exp.location}
          highlights={exp.highlights}
          stack={exp.stack}
          technicalDetails={exp.technicalDetails}
          defaultOpen={exp.defaultOpen}
        />
      ))
    }
  </div>
</div>

<script is:inline>
  const initExperienceToggles = () => {
    document.querySelectorAll('[data-experience-toggle]').forEach((button) => {
      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';

      button.addEventListener('click', () => {
        const panelId = button.getAttribute('aria-controls');
        if (!panelId) return;

        const panel = document.getElementById(panelId);
        if (!panel) return;

        const expanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!expanded));
        panel.hidden = expanded;
      });
    });
  };

  if (document.readyState !== 'loading') initExperienceToggles();
  document.addEventListener('DOMContentLoaded', initExperienceToggles, { once: true });
  document.addEventListener('astro:page-load', initExperienceToggles);
</script>
