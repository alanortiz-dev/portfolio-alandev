---
import LinkInline from './LinkInline.astro';
import { useTranslations } from '../i18n/utils';
import { languageList } from '../i18n/ui';

interface Props {
  title: string;
  company: string;
  description: string;
  link?: string;
  date: string;
  location?: string;
  highlights?: string[];
}

const { title, company, description, link, date, location, highlights = [] } = Astro.props;

const currentLang = Astro.currentLocale;
const t = useTranslations(currentLang as keyof typeof languageList);
---

<div class="relative ml-6 border-l border-slate-200 pb-12 pl-8 dark:border-white/10 md:ml-0 md:grid md:grid-cols-[220px_minmax(0,1fr)] md:gap-12 md:border-l-0 md:pl-0">
  <div class="relative pb-6 md:pb-0">
    <span class="absolute -left-[2.45rem] top-1 size-3 rounded-full border-4 border-white bg-slate-900 dark:border-slate-950 dark:bg-slate-200 md:left-auto md:-right-1.5"></span>
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{date}</p>
    <h3 class="mt-3 text-xl font-semibold text-slate-950 dark:text-white">{title}</h3>
    <h4 class="text-sm text-slate-600 dark:text-slate-300">{company}</h4>
    {location && <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{location}</p>}
  </div>

  <div class="rounded-[2rem] bg-white/90 p-6 shadow-sm shadow-slate-200/20 ring-1 ring-slate-200/70 dark:bg-white/[0.03] dark:ring-white/10 dark:shadow-none lg:p-7">
    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">{description}</p>

    {highlights.length > 0 && (
      <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300">
        {highlights.map((highlight) => <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-slate-400 dark:bg-slate-500"></span><span>{highlight}</span></li>)}
      </ul>
    )}

    {
      link && (
        <div class="mt-4">
          <LinkInline href={link}>{t('experience.visitSite')} ↗</LinkInline>
        </div>
      )
    }
  </div>
</div>
