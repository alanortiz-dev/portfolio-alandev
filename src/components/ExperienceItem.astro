---
interface Props {
  index: number;
  role: string;
  company: string;
  summary: string;
  link?: string;
  period: string;
  location?: string;
  highlights?: string[];
  stack?: string[];
  technicalDetails?: string[];
  defaultOpen?: boolean;
}

const {
  index,
  role,
  company,
  summary,
  link,
  period,
  location,
  highlights = [],
  stack = [],
  technicalDetails = [],
  defaultOpen = false,
} = Astro.props;

const currentLang = (Astro.currentLocale || 'es') as 'es' | 'en';
const ui = currentLang === 'en'
  ? {
      viewDetails: 'View details',
      hideDetails: 'Hide details',
      mainStack: 'Main stack',
      highlights: 'Highlights',
      technicalDetails: 'Technical details',
      visitSite: 'Visit site',
    }
  : {
      viewDetails: 'Ver detalles',
      hideDetails: 'Ocultar detalles',
      mainStack: 'Stack principal',
      highlights: 'Puntos clave',
      technicalDetails: 'Detalles técnicos',
      visitSite: 'Visitar sitio',
    };

const panelId = `experience-panel-${currentLang}-${index}`;
const titleId = `experience-title-${currentLang}-${index}`;
---

<article class="rounded-[1.8rem] bg-white/92 p-5 shadow-sm shadow-slate-200/20 ring-1 ring-slate-200/70 dark:bg-white/[0.03] dark:ring-white/10 dark:shadow-none sm:p-6 lg:p-7">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-4">
      <div class="flex flex-wrap gap-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">
        <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-white/[0.06]">{period}</span>
        {location && <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-white/[0.06]">{location}</span>}
      </div>

      <div class="space-y-2">
        <h3 id={titleId} class="text-xl font-semibold text-slate-950 dark:text-white sm:text-[1.35rem]">{role}</h3>
        <p class="text-sm font-medium text-emerald-700 dark:text-emerald-300">{company}</p>
        <p class="max-w-3xl text-sm leading-7 text-slate-600 dark:text-slate-300">{summary}</p>
      </div>

      {stack.length > 0 && (
        <div class="space-y-3">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.mainStack}</p>
          <ul class="flex flex-wrap gap-2">
            {stack.map((item) => (
              <li class="rounded-full border border-slate-200/80 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700 dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-200">
                {item}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <button
      type="button"
      class="experience-toggle inline-flex min-h-10 items-center gap-2 self-start rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.06] dark:hover:text-white"
      aria-expanded={defaultOpen ? 'true' : 'false'}
      aria-controls={panelId}
      data-experience-toggle
    >
      <span class="experience-toggle__label experience-toggle__label--show">{ui.viewDetails}</span>
      <span class="experience-toggle__label experience-toggle__label--hide">{ui.hideDetails}</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon size-4" aria-hidden="true">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </button>
  </div>

  <div
    id={panelId}
    class="mt-6 space-y-6 border-t border-slate-200/70 pt-6 dark:border-white/10"
    aria-labelledby={titleId}
    hidden={!defaultOpen}
  >
    {highlights.length > 0 && (
      <div class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.highlights}</p>
        <ul class="space-y-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
          {highlights.map((highlight) => (
            <li class="flex gap-3">
              <span class="mt-3 size-1.5 shrink-0 rounded-full bg-emerald-500 dark:bg-emerald-300"></span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {technicalDetails.length > 0 && (
      <div class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">{ui.technicalDetails}</p>
        <ul class="space-y-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
          {technicalDetails.map((detail) => (
            <li class="flex gap-3">
              <span class="mt-3 size-1.5 shrink-0 rounded-full bg-slate-400 dark:bg-slate-500"></span>
              <span>{detail}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {
      link && (
        <div>
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-sm font-semibold text-emerald-700 transition hover:text-emerald-600 dark:text-emerald-300 dark:hover:text-emerald-200"
          >
            {ui.visitSite} ↗
          </a>
        </div>
      )
    }
  </div>
</article>

<style>
  .experience-toggle__label--hide {
    display: none;
  }

  .experience-toggle[aria-expanded='true'] .experience-toggle__label--show {
    display: none;
  }

  .experience-toggle[aria-expanded='true'] .experience-toggle__label--hide {
    display: inline;
  }

  .toggle-icon {
    transition: transform 180ms ease;
  }

  .experience-toggle[aria-expanded='true'] .toggle-icon {
    transform: rotate(180deg);
  }
</style>
