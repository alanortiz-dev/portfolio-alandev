---
import type { HomeContent } from '@/data/homeContent';

export interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const sliderId = `professional-experience-${Astro.currentLocale || 'es'}`;
---

<div class="space-y-5">
  <div class="flex items-center justify-between gap-3">
    <p class="text-sm text-slate-500 dark:text-slate-400">
      {Astro.currentLocale === 'en' ? 'Scroll through the full experience' : 'Desliza para ver toda la experiencia'}
    </p>

    <div class="flex items-center gap-2">
      <button
        type="button"
        class="inline-flex size-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.08]"
        data-slider-prev={sliderId}
        aria-label={Astro.currentLocale === 'en' ? 'Scroll experience left' : 'Desplazar experiencia a la izquierda'}
      >
        <span aria-hidden="true">←</span>
      </button>
      <button
        type="button"
        class="inline-flex size-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50 focus:outline-none focus-visible:ring focus-visible:ring-slate-300 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-200 dark:hover:bg-white/[0.08]"
        data-slider-next={sliderId}
        aria-label={Astro.currentLocale === 'en' ? 'Scroll experience right' : 'Desplazar experiencia a la derecha'}
      >
        <span aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <div
    id={sliderId}
    class="flex snap-x snap-mandatory gap-5 overflow-x-auto pb-4 [scrollbar-width:thin] [scrollbar-color:rgba(148,163,184,.7)_transparent]"
  >
    {
      content.experiences.map((item) => (
        <article class="min-w-[290px] max-w-[360px] flex-1 snap-start rounded-[2rem] bg-white/90 p-6 shadow-sm shadow-slate-200/20 ring-1 ring-slate-200/70 dark:bg-white/[0.03] dark:ring-white/10 dark:shadow-none lg:p-7">
          <div class="space-y-4">
            <div>
              <p class="text-xs font-medium uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold text-slate-950 dark:text-white">{item.role}</h3>
              <p class="text-sm text-slate-600 dark:text-slate-300">{item.company} · {item.location}</p>
            </div>

            <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">{item.summary}</p>

            <ul class="space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300">
              {item.highlights.slice(0, 3).map((highlight) => <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-slate-400 dark:bg-slate-500"></span><span>{highlight}</span></li>)}
            </ul>
          </div>
        </article>
      ))
    }
  </div>
</div>

<script is:inline>
  const setupExperienceSlider = () => {
    document.querySelectorAll('[data-slider-prev], [data-slider-next]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement) || button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        const key = button.getAttribute('data-slider-prev') || button.getAttribute('data-slider-next');
        if (!key) return;
        const slider = document.getElementById(key);
        if (!slider) return;
        const direction = button.hasAttribute('data-slider-next') ? 1 : -1;
        slider.scrollBy({ left: slider.clientWidth * 0.82 * direction, behavior: 'smooth' });
      });
    });
  };

  setupExperienceSlider();
  document.addEventListener('astro:after-swap', setupExperienceSlider);
</script>
